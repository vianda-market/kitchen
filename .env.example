# Kitchen API - Environment Template
# Copy to .env and fill in values. Never commit .env.

# =============================================================================
# Required - Authentication
# =============================================================================
SECRET_KEY=your-secret-key-min-32-chars-for-hs256
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# =============================================================================
# Required - Database (PostgreSQL)
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kitchen
DB_USER=postgres
DB_PASSWORD=your-db-password

# Optional: Connection pool (defaults shown)
# DB_POOL_MIN_CONNECTIONS=5
# DB_POOL_MAX_CONNECTIONS=20

# =============================================================================
# Optional - Environment (local, dev, staging, prod; local uses GOOGLE_API_KEY_DEV)
# =============================================================================
# ENVIRONMENT=local

# =============================================================================
# Optional - Development
# =============================================================================
# DEV_MODE=true
# DEV_OVERRIDE_DAY=   # e.g. "Monday" for testing
# DEBUG_PASSWORD_RECOVERY=false
# LOG_EMAIL_TRACKING=false
# LOG_EMPLOYER_ASSIGN=0

# =============================================================================
# Optional - Frontend URLs (for invite links, password reset, etc.)
# =============================================================================
# B2B_INVITE_SET_PASSWORD_URL=
# B2B_FRONTEND_URL=http://localhost:5173

# =============================================================================
# Optional - Payment (use mock for dev)
# =============================================================================
# PAYMENT_PROVIDER=mock
# SUPPLIER_PAYOUT_PROVIDER=mock
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PUBLISHABLE_KEY=
# Default success_url for POST /customer/payment-methods/setup-session when body omits it (cancel_url defaults to same)
# STRIPE_CUSTOMER_SETUP_SUCCESS_URL=https://your-b2c-app.example/settings/payment
# Stripe Connect (supplier outbound payouts; separate from inbound STRIPE_WEBHOOK_SECRET)
# STRIPE_CONNECT_WEBHOOK_SECRET=   # whsec_… from Stripe Connect webhook endpoint (sandbox or live)
# STRIPE_PLATFORM_ACCOUNT_ID=      # acct_… platform account (optional; for logging/Stripe support)

# =============================================================================
# Optional - External APIs (leave empty for DEV_MODE mock responses)
# =============================================================================
# Google API Keys per environment; local uses GOOGLE_API_KEY_DEV
# GOOGLE_API_KEY_DEV=
# GOOGLE_API_KEY_STAGING=
# GOOGLE_API_KEY_PROD=

# =============================================================================
# Optional - GCS Storage (empty = local storage; set by infra on Cloud Run)
# =============================================================================
# GCS_INTERNAL_BUCKET=
# GCS_SUPPLIER_BUCKET=
# GCS_CUSTOMER_BUCKET=
# GCS_EMPLOYER_BUCKET=
# GCS_SIGNED_URL_EXPIRATION_SECONDS=3600
# GCS_QR_SIGNED_URL_EXPIRATION_SECONDS=86400
# GCS_SIGNING_SA_EMAIL=  # Set by infra for signed URLs (Cloud Run SA email)

# Product image upload: max file size in bytes (default 5242880 = 5 MB)
# MAX_PRODUCT_IMAGE_BYTES=5242880

# =============================================================================
# Optional - Fixed institution IDs (must match seed.sql)
# =============================================================================
# VIANDA_CUSTOMERS_INSTITUTION_ID=22222222-2222-2222-2222-222222222222
# VIANDA_ENTERPRISES_INSTITUTION_ID=11111111-1111-1111-1111-111111111111
