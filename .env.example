# Kitchen API - Environment Template
# Copy to .env and fill in values. Never commit .env.

# =============================================================================
# Required - Authentication
# =============================================================================
SECRET_KEY=your-secret-key-min-32-chars-for-hs256
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# =============================================================================
# Required - Database (PostgreSQL)
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kitchen
DB_USER=postgres
DB_PASSWORD=your-db-password

# Optional: Connection pool (defaults shown)
# DB_POOL_MIN_CONNECTIONS=5
# DB_POOL_MAX_CONNECTIONS=20

# =============================================================================
# Optional - Environment (local, dev, staging, prod; local uses GOOGLE_API_KEY_DEV)
# =============================================================================
# ENVIRONMENT=local

# =============================================================================
# Optional - Development
# =============================================================================
# DEV_MODE=true
# DEV_OVERRIDE_DAY=   # e.g. "Monday" for testing
# DEBUG_PASSWORD_RECOVERY=false
# LOG_EMAIL_TRACKING=false
# LOG_EMPLOYER_ASSIGN=0

# =============================================================================
# Optional - Frontend URLs (for invite links, password reset, etc.)
# =============================================================================
# B2B_INVITE_SET_PASSWORD_URL=
# B2B_FRONTEND_URL=http://localhost:5173

# =============================================================================
# Optional - Payment (use mock for dev)
# =============================================================================
# PAYMENT_PROVIDER=mock
# SUPPLIER_PAYOUT_PROVIDER=mock
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PUBLISHABLE_KEY=
# Default success_url for POST /customer/payment-methods/setup-session when body omits it (cancel_url defaults to same)
# STRIPE_CUSTOMER_SETUP_SUCCESS_URL=https://your-b2c-app.example/settings/payment
# Stripe Connect (supplier outbound payouts; separate from inbound STRIPE_WEBHOOK_SECRET)
# STRIPE_CONNECT_WEBHOOK_SECRET=   # whsec_… from Stripe Connect webhook endpoint (sandbox or live)
# STRIPE_PLATFORM_ACCOUNT_ID=      # acct_… platform account (optional; for logging/Stripe support)

# =============================================================================
# Optional - Email Provider
# =============================================================================
# EMAIL_PROVIDER=smtp                       # "smtp" (Gmail, default) or "sendgrid" (production)
# SENDGRID_API_KEY=                         # Required when EMAIL_PROVIDER=sendgrid
# EMAIL_FROM_ADDRESS=hello@vianda.market  # Sender address (falls back to FROM_EMAIL)
# EMAIL_FROM_NAME=Vianda                    # Sender display name (falls back to FROM_NAME)
# EMAIL_REPLY_TO=support@vianda.market      # Reply-to address

# SMTP (used when EMAIL_PROVIDER=smtp; current dev default)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-specific-password
# FROM_EMAIL=your-email@gmail.com
# FROM_NAME=Vianda

# =============================================================================
# Optional - External APIs (leave empty for DEV_MODE mock responses)
# =============================================================================
# Google API Keys per environment; local uses GOOGLE_API_KEY_DEV (fallback provider)
# GOOGLE_API_KEY_DEV=
# GOOGLE_API_KEY_STAGING=
# GOOGLE_API_KEY_PROD=

# Mapbox Access Tokens per environment; local uses MAPBOX_ACCESS_TOKEN_DEV
# MAPBOX_ACCESS_TOKEN_DEV=
# MAPBOX_ACCESS_TOKEN_STAGING=
# MAPBOX_ACCESS_TOKEN_PROD=

# Persistent-storage Mapbox token (sk.*). Used by callsites that write
# lat/lng to DB. DEV's MAPBOX_CACHE_MODE defaults to replay_only, so the
# persistent token is only billed when a dev manually flips MAPBOX_CACHE_MODE
# to "record" to add a new demo address. Uncomment the relevant line and
# fill from GCP Secret Manager (vianda-<stack>-mapbox-token-persistent).
# MAPBOX_ACCESS_TOKEN_DEV_PERSISTENT=
# MAPBOX_ACCESS_TOKEN_STAGING_PERSISTENT=
# MAPBOX_ACCESS_TOKEN_PROD_PERSISTENT=

# Address/geocoding provider: "mapbox" (default) or "google" (fallback)
# ADDRESS_PROVIDER=mapbox

# =============================================================================
# Optional - GCS Storage (empty = local storage; set by infra on Cloud Run)
# =============================================================================
# GCS_INTERNAL_BUCKET=
# GCS_SUPPLIER_BUCKET=
# GCS_CUSTOMER_BUCKET=
# GCS_EMPLOYER_BUCKET=
# GCS_SIGNED_URL_EXPIRATION_SECONDS=3600
# GCS_QR_SIGNED_URL_EXPIRATION_SECONDS=86400
# GCS_SIGNING_SA_EMAIL=  # Set by infra for signed URLs (Cloud Run SA email)

# Product image upload: max file size in bytes (default 5242880 = 5 MB)
# MAX_PRODUCT_IMAGE_BYTES=5242880

# =============================================================================
# Optional - Fixed institution IDs (must match seed.sql)
# =============================================================================
# VIANDA_CUSTOMERS_INSTITUTION_ID=22222222-2222-2222-2222-222222222222
# VIANDA_ENTERPRISES_INSTITUTION_ID=11111111-1111-1111-1111-111111111111

# =============================================================================
# Optional - Ingredient Enrichment Cron
# =============================================================================
# WIKIDATA_ENRICHMENT_ENABLED=false   # Image enrichment via Wikidata (CC licensed)
# USDA_ENRICHMENT_ENABLED=false       # Nutrition enrichment via USDA (Phase 7)
# ENRICHMENT_BATCH_SIZE=50            # Rows per cron run

# Spoonacular — future partnership only; real value stored in GCP Secret Manager, never committed here
# SPOONACULAR_ENABLED=false
# SPOONACULAR_API_KEY=

# =============================================================================
# Optional - QR Code Signing (HMAC-SHA256 for signed QR URLs)
# =============================================================================
# QR_HMAC_SECRET=your-random-hex-secret-min-32-chars

# =============================================================================
# Optional - Pickup Timer & Handoff (B2C countdown + B2B kiosk handoff)
# =============================================================================
# PICKUP_COUNTDOWN_SECONDS=300
# PICKUP_MAX_EXTENSIONS=3
# HANDOFF_CONFIRMATION_TIMEOUT_SECONDS=300

# =============================================================================
# Optional - Dispute Escalation (auto-upgrade restaurants to code verification)
# =============================================================================
# DISPUTE_AUTO_ESCALATION_RATE=0.03
# DISPUTE_ESCALATION_MIN_ORDERS=20
# DISPUTE_ESCALATION_LOOKBACK_DAYS=30
# PORTION_COMPLAINT_FLAG_RATE=0.05

# =============================================================================
# Optional - Firebase Cloud Messaging (push notifications)
# =============================================================================
# FIREBASE_CREDENTIALS_PATH=  # Path to Firebase service account JSON

# =============================================================================
# Optional - Postman MCP (for Claude Code /postman commands)
# =============================================================================
# POSTMAN_API_KEY=

# =============================================================================
# Optional - reCAPTCHA v3 (bot protection for public /leads/* endpoints)
# =============================================================================
# RECAPTCHA_SECRET_KEY=
# RECAPTCHA_SCORE_THRESHOLD=0.3

# Conditional reCAPTCHA: per-endpoint thresholds (0 = disabled). Defaults shown.
# LOGIN_CAPTCHA_THRESHOLD=5
# LOGIN_CAPTCHA_WINDOW_SECONDS=900
# SIGNUP_VERIFY_CAPTCHA_THRESHOLD=3
# SIGNUP_VERIFY_CAPTCHA_WINDOW_SECONDS=900
# FORGOT_PASSWORD_CAPTCHA_THRESHOLD=3
# FORGOT_PASSWORD_CAPTCHA_WINDOW_SECONDS=900
# FORGOT_USERNAME_CAPTCHA_THRESHOLD=3
# FORGOT_USERNAME_CAPTCHA_WINDOW_SECONDS=900
# RESET_PASSWORD_CAPTCHA_THRESHOLD=3
# RESET_PASSWORD_CAPTCHA_WINDOW_SECONDS=900
# CAPTCHA_MAX_TRACKED_IPS=10000
# CAPTCHA_EVICTION_AGE_SECONDS=1800

# =============================================================================
# Optional - CORS (comma-separated allowed origins; empty = allow all for local dev)
# =============================================================================
# CORS_ALLOWED_ORIGINS=https://dev.vianda.market,https://platform.dev.vianda.market,https://api.dev.vianda.market,http://localhost:8081,http://localhost:3000,http://localhost:5173
