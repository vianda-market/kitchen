        {
          "name": "GET /plates/enriched \u2013 filter by service date range (pickup_date gte/lte via psi join)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response is array', function () {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "pm.test('Row count does not exceed unfiltered baseline (no row inflation from psi join)', function () {",
                  "    // A date filter can only reduce (or equal) the unfiltered count — it cannot",
                  "    // inflate it. If distinct=True is working correctly, the filtered result is a",
                  "    // subset of the unfiltered result. This guards against the 1:N join inflating",
                  "    // plate rows when plate_selection_info has multiple reservations per plate.",
                  "    var baseline = pm.collectionVariables.get('platesBaselineCount');",
                  "    pm.expect(pm.response.json().length).to.be.at.most(parseInt(baseline));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
