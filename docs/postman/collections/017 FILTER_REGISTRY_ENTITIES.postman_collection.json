        {
          "name": "GET /restaurants/enriched – search (ilike OR name+tagline)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response is array', function () {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "// Results should have name or tagline containing the search term (case-insensitive)",
                  "const term = 'Vianda';",
                  "const restaurants = pm.response.json();",
                  "restaurants.forEach(function(r) {",
                  "    pm.test('Restaurant name or tagline matches search term', function () {",
                  "        const nameMatch = r.name && r.name.toLowerCase().includes(term.toLowerCase());",
                  "        const taglineMatch = r.tagline && r.tagline.toLowerCase().includes(term.toLowerCase());",
                  "        pm.expect(nameMatch || taglineMatch).to.be.true;",
                  "    });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
