    {
      "name": "Geo Filters (restaurants)",
      "description": "Geo bbox and radius filter tests for GET /restaurants/enriched. Requires PostGIS installed and ops.restaurant_info.location populated with seed data. Use a bbox / center point that covers at least one seeded restaurant to verify a 200 with results.",
      "item": [
        {
          "name": "GET /restaurants/enriched \u2013 bbox (wide NYC area, expects results if seeded)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response is an array', function () {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "// Uncomment to assert at least one result when seed data is present:",
                  "// pm.test('At least one restaurant in bbox', function () {",
                  "//     pm.expect(pm.response.json().length).to.be.above(0);",
                  "// });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminAuthToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/restaurants/enriched?bbox=-74.05,40.68,-73.91,40.83",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "restaurants",
                "enriched"
              ],
              "query": [
                {
                  "key": "bbox",
                  "value": "-74.05,40.68,-73.91,40.83",
                  "description": "min_lng,min_lat,max_lng,max_lat \u2014 NYC bounding box"
                }
              ]
            }
          }
        },
