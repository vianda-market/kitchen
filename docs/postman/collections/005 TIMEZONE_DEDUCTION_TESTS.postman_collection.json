{
  "info": {
    "_postman_id": "timezone-deduction-tests-2026",
    "name": "005 TIMEZONE_DEDUCTION_TESTS",
    "description": "Timezone auto-deduction tests limited to Argentina (AR). Run after 000/001. Other markets (US, PE, CL) are not created in Postman collection runs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.0.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// Use admin from 001 (env or globals) when available",
          "const u = pm.environment.get('adminUsername') || pm.globals.get('adminUsername');",
          "if (u) pm.collectionVariables.set('adminUsername', u);",
          "const p = pm.environment.get('adminPassword') || pm.globals.get('adminPassword');",
          "if (p) pm.collectionVariables.set('adminPassword', p);",
          "const t = pm.environment.get('authToken') || pm.globals.get('authToken') || pm.environment.get('adminAuthToken') || pm.globals.get('adminAuthToken');",
          "if (t) pm.collectionVariables.set('authToken', t);"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Login as Employee",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "pm.test('Response has access_token', function () {",
                  "    pm.expect(response).to.have.property('access_token');",
                  "});",
                  "",
                  "pm.collectionVariables.set('authToken', response.access_token);",
                  "pm.environment.set('authToken', response.access_token);",
                  "pm.globals.set('authToken', response.access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "{{superAdminUsername}}"
                },
                {
                  "key": "password",
                  "value": "{{superAdminPassword}}"
                }
              ]
            },
            "url": "{{baseUrl}}/api/v1/auth/token"
          }
        },
        {
          "name": "Setup: Resolve City Metadata (PR4c)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Find any available token so Setup works across collections that use different names.",
                  "const token = pm.collectionVariables.get('authToken')",
                  "    || pm.environment.get('authToken')",
                  "    || pm.collectionVariables.get('employeeAdminToken')",
                  "    || pm.environment.get('employeeAdminToken')",
                  "    || pm.collectionVariables.get('superAdminAuthToken')",
                  "    || pm.environment.get('superAdminAuthToken')",
                  "    || pm.collectionVariables.get('adminAuthToken')",
                  "    || pm.environment.get('adminAuthToken');",
                  "if (token) {",
                  "    pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + token });",
                  "} else {",
                  "    console.warn('No auth token available for Setup Cities — GET /cities will 401');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// PR4c setup: pre-populate cityMetadataId{CC} cache for every seeded market",
                  "// so downstream address-create injectors can read synchronously.",
                  "pm.test('Cities list returned', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const cities = pm.response.json();",
                  "if (Array.isArray(cities)) {",
                  "    const byCC = {};",
                  "    for (const c of cities) {",
                  "        const cc = (c.country_code || '').toUpperCase();",
                  "        if (!cc || byCC[cc]) continue;",
                  "        byCC[cc] = c;",
                  "    }",
                  "    for (const cc in byCC) {",
                  "        const city = byCC[cc];",
                  "        if (!city || !city.city_metadata_id) continue;",
                  "        const varName = 'cityMetadataId' + cc;",
                  "        pm.collectionVariables.set(varName, city.city_metadata_id);",
                  "        pm.environment.set(varName, city.city_metadata_id);",
                  "        pm.globals.set(varName, city.city_metadata_id);",
                  "        console.log('cached', varName, '=', city.city_metadata_id, '(' + city.name + ')');",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/cities",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "cities"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get current user (set testUserId, testInstitutionId)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "const r = pm.response.json();",
                  "pm.test('Response has user_id and institution_id (required for address tests)', function () { pm.expect(r).to.have.property('user_id'); pm.expect(r).to.have.property('institution_id'); });\nif (r.user_id && r.institution_id) { pm.collectionVariables.set('testUserId', r.user_id); pm.collectionVariables.set('testInstitutionId', r.institution_id); pm.environment.set('testUserId', r.user_id); pm.environment.set('testInstitutionId', r.institution_id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/v1/users/me"
          }
        }
      ]
    },
    {
      "name": "📍 Argentina (AR)",
      "item": [
        {
          "name": "Get current user (set testUserId, testInstitutionId)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "const r = pm.response.json();",
                  "pm.test('Response has user_id and institution_id (required for address tests)', function () { pm.expect(r).to.have.property('user_id'); pm.expect(r).to.have.property('institution_id'); });\nif (r.user_id && r.institution_id) { pm.collectionVariables.set('testUserId', r.user_id); pm.collectionVariables.set('testInstitutionId', r.institution_id); pm.environment.set('testUserId', r.user_id); pm.environment.set('testInstitutionId', r.institution_id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/v1/users/me"
          }
        },
        {
          "name": "Create Address - Argentina (AR)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "",
                  "pm.test('Response has timezone', function () {",
                  "    pm.expect(response).to.have.property('timezone');",
                  "});",
                  "",
                  "pm.test('Timezone is America/Argentina/Buenos_Aires', function () {",
                  "    pm.expect(response.timezone).to.equal('America/Argentina/Buenos_Aires');",
                  "});",
                  "",
                  "pm.test('country_code is AR (alpha-2)', function () {",
                  "    pm.expect(response.country_code).to.equal('AR');",
                  "});",
                  "",
                  "pm.test('country_name is Argentina', function () {",
                  "    pm.expect(response.country_name).to.equal('Argentina');",
                  "});",
                  "",
                  "pm.collectionVariables.set('testAddressArgId', response.address_id);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "",
                  "// PR4a: resolve city_metadata_id from /cities and inject into the request body.",
                  "// Supports nested address (Create Employer Atomic: payload.address.*) and flat bodies.",
                  "// Caches the resolved id at collection + environment scope keyed by country_code.",
                  "// Safe for negative-case tests: if country_code is missing or the API returns nothing,",
                  "// the injector early-returns and the legacy timezone_service path handles the request.",
                  "(function injectCityMetadataId() {",
                  "    try {",
                  "        let raw = pm.request.body && pm.request.body.raw ? pm.request.body.raw : '{}';",
                  "        if (!raw || !raw.trim()) return;",
                  "        let payload;",
                  "        try { payload = JSON.parse(raw); } catch (e) { return; }",
                  "        const target = (payload && payload.address) ? payload.address : payload;",
                  "        if (!target || typeof target !== 'object') return;",
                  "        if (target.city_metadata_id) return;",
                  "        const cc = (target.country_code || '').toUpperCase();",
                  "        if (!cc) return;",
                  "        const varName = 'cityMetadataId' + cc;",
                  "        let cmid = pm.collectionVariables.get(varName) || pm.environment.get(varName);",
                  "        if (cmid) {",
                  "            target.city_metadata_id = cmid;",
                  "            pm.request.body.update(JSON.stringify(payload));",
                  "            return;",
                  "        }",
                  "        const token = pm.environment.get('authToken')",
                  "            || pm.collectionVariables.get('authToken')",
                  "            || pm.collectionVariables.get('superAdminAuthToken')",
                  "            || pm.environment.get('superAdminAuthToken');",
                  "        const baseUrl = pm.environment.get('baseUrl') || pm.collectionVariables.get('baseUrl') || 'http://localhost:8000';",
                  "        if (!token) return;",
                  "        pm.sendRequest({",
                  "            url: baseUrl + '/api/v1/cities?country_code=' + cc,",
                  "            method: 'GET',",
                  "            header: { 'Authorization': 'Bearer ' + token }",
                  "        }, (err, res) => {",
                  "            if (err || !res || res.code !== 200) return;",
                  "            let cities;",
                  "            try { cities = res.json(); } catch (e) { return; }",
                  "            if (!Array.isArray(cities) || cities.length === 0) return;",
                  "            const first = cities.find(c => (c.country_code || '').toUpperCase() === cc) || cities[0];",
                  "            if (!first || !first.city_metadata_id) return;",
                  "            pm.collectionVariables.set(varName, first.city_metadata_id);",
                  "            pm.environment.set(varName, first.city_metadata_id);",
                  "            target.city_metadata_id = first.city_metadata_id;",
                  "            pm.request.body.update(JSON.stringify(payload));",
                  "        });",
                  "    } catch (e) { console.warn('city_metadata_id injector skipped:', e.message); }",
                  "})();"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"institution_id\": \"{{testInstitutionId}}\",\n  \"user_id\": \"{{testUserId}}\",\n  \"address_type\": [\n    \"restaurant\"\n  ],\n  \"country_code\": \"AR\",\n  \"province\": \"CABA\",\n  \"city\": \"Buenos Aires\",\n  \"postal_code\": \"C1000\",\n  \"street_type\": \"ave\",\n  \"street_name\": \"Corrientes\",\n  \"building_number\": \"1234\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/addresses"
          }
        }
      ]
    },
    {
      "name": "⚠️ Edge Cases (validation only)",
      "item": [
        {
          "name": "Invalid Country Code (Should Return 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Backend returns 400 'Invalid country_code' when schema validation passes but market lookup fails.",
                  "// Pydantic may return 422 if env-level variables shadow collection defaults (e.g. empty testInstitutionId).",
                  "// Accept either as 'request rejected for invalid input'.",
                  "pm.test('Invalid country rejected (400 or 422)', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([400, 422]);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "const detail = Array.isArray(body.detail) ? body.detail.map(d => d.msg || JSON.stringify(d)).join(' ') : (body.detail || '');",
                  "pm.test('Error mentions invalid input', function () {",
                  "    pm.expect(detail.toLowerCase()).to.match(/invalid|not found|required|country/i);",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "",
                  "// PR4a: resolve city_metadata_id from /cities and inject into the request body.",
                  "// Supports nested address (Create Employer Atomic: payload.address.*) and flat bodies.",
                  "// Caches the resolved id at collection + environment scope keyed by country_code.",
                  "// Safe for negative-case tests: if country_code is missing or the API returns nothing,",
                  "// the injector early-returns and the legacy timezone_service path handles the request.",
                  "(function injectCityMetadataId() {",
                  "    try {",
                  "        let raw = pm.request.body && pm.request.body.raw ? pm.request.body.raw : '{}';",
                  "        if (!raw || !raw.trim()) return;",
                  "        let payload;",
                  "        try { payload = JSON.parse(raw); } catch (e) { return; }",
                  "        const target = (payload && payload.address) ? payload.address : payload;",
                  "        if (!target || typeof target !== 'object') return;",
                  "        if (target.city_metadata_id) return;",
                  "        const cc = (target.country_code || '').toUpperCase();",
                  "        if (!cc) return;",
                  "        const varName = 'cityMetadataId' + cc;",
                  "        let cmid = pm.collectionVariables.get(varName) || pm.environment.get(varName);",
                  "        if (cmid) {",
                  "            target.city_metadata_id = cmid;",
                  "            pm.request.body.update(JSON.stringify(payload));",
                  "            return;",
                  "        }",
                  "        const token = pm.environment.get('authToken')",
                  "            || pm.collectionVariables.get('authToken')",
                  "            || pm.collectionVariables.get('superAdminAuthToken')",
                  "            || pm.environment.get('superAdminAuthToken');",
                  "        const baseUrl = pm.environment.get('baseUrl') || pm.collectionVariables.get('baseUrl') || 'http://localhost:8000';",
                  "        if (!token) return;",
                  "        pm.sendRequest({",
                  "            url: baseUrl + '/api/v1/cities?country_code=' + cc,",
                  "            method: 'GET',",
                  "            header: { 'Authorization': 'Bearer ' + token }",
                  "        }, (err, res) => {",
                  "            if (err || !res || res.code !== 200) return;",
                  "            let cities;",
                  "            try { cities = res.json(); } catch (e) { return; }",
                  "            if (!Array.isArray(cities) || cities.length === 0) return;",
                  "            const first = cities.find(c => (c.country_code || '').toUpperCase() === cc) || cities[0];",
                  "            if (!first || !first.city_metadata_id) return;",
                  "            pm.collectionVariables.set(varName, first.city_metadata_id);",
                  "            pm.environment.set(varName, first.city_metadata_id);",
                  "            target.city_metadata_id = first.city_metadata_id;",
                  "            pm.request.body.update(JSON.stringify(payload));",
                  "        });",
                  "    } catch (e) { console.warn('city_metadata_id injector skipped:', e.message); }",
                  "})();"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"institution_id\": \"{{testInstitutionId}}\",\n  \"user_id\": \"{{testUserId}}\",\n  \"address_type\": [\n    \"restaurant\"\n  ],\n  \"country_code\": \"XX\",\n  \"province\": \"SomeProvince\",\n  \"city\": \"SomeCity\",\n  \"postal_code\": \"00000\",\n  \"street_type\": \"st\",\n  \"street_name\": \"Test\",\n  \"building_number\": \"777\",\n  \"city_metadata_id\": \"11111111-1111-1111-1111-111111111111\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/addresses"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    },
    {
      "key": "superAdminUsername",
      "value": ""
    },
    {
      "key": "superAdminPassword",
      "value": ""
    },
    {
      "key": "authToken",
      "value": ""
    },
    {
      "key": "testInstitutionId",
      "value": "11111111-1111-1111-1111-111111111111"
    },
    {
      "key": "testUserId",
      "value": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa"
    },
    {
      "key": "testAddressArgId",
      "value": ""
    }
  ]
}