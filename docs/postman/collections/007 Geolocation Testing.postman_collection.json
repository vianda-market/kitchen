{
	"info": {
		"_postman_id": "geo-test-001",
		"name": "007 Geolocation Testing",
		"description": "Tests for geolocation service functionality including geocoding, reverse geocoding, and distance calculations. Works in both DEV_MODE (mock responses) and production mode (real Mapbox Geocoding API). Provider controlled by ADDRESS_PROVIDER setting (default: mapbox).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"exec": [
					"// Use admin from 001 (env or globals) when available",
					"const u = pm.environment.get('adminUsername') || pm.globals.get('adminUsername');",
					"if (u) pm.collectionVariables.set('adminUsername', u);",
					"const p = pm.environment.get('adminPassword') || pm.globals.get('adminPassword');",
					"if (p) pm.collectionVariables.set('adminPassword', p);",
					"const t = pm.environment.get('authToken') || pm.globals.get('authToken') || pm.environment.get('adminAuthToken') || pm.globals.get('adminAuthToken');",
					"if (t) { pm.collectionVariables.set('authToken', t); pm.collectionVariables.set('adminAuthToken', t); }"
				],
				"type": "text/javascript"
			}
		}
	],
	"item": [
		{
			"name": "Setup & Authentication",
			"item": [
				{
					"name": "Login Vianda Admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Login successful\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"const { access_token } = pm.response.json();",
									"pm.environment.set(\"authToken\", access_token);",
									"pm.environment.set(\"adminAuthToken\", access_token);",
									"pm.collectionVariables.set(\"authToken\", access_token);",
									"pm.collectionVariables.set(\"adminAuthToken\", access_token);",
									"pm.globals.set(\"authToken\", access_token);",
									"pm.globals.set(\"adminAuthToken\", access_token);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "username",
									"value": "{{superAdminUsername}}",
									"type": "text"
								},
								{
									"key": "password",
									"value": "{{superAdminPassword}}",
									"type": "text"
								}
							]
						},
						"url": "{{baseUrl}}/api/v1/auth/token"
					}
				}
			]
		},
		{
			"name": "Geocoding Tests (Address to Coordinates)",
			"item": [
				{
					"name": "Query Test Address",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Query for any active address to test with",
									"const baseUrl = pm.collectionVariables.get('baseUrl') || pm.environment.get('baseUrl') || 'http://localhost:8000';",
									"const token = pm.collectionVariables.get('adminAuthToken') || pm.environment.get('adminAuthToken');",
									"pm.sendRequest({",
									"    url: baseUrl + '/api/v1/addresses',",
									"    method: 'GET',",
									"    header: {",
									"        'Authorization': 'Bearer ' + token",
									"    }",
									"}, function(err, res) {",
									"    if (err) {",
									"        console.error('Error querying addresses:', err);",
									"        return;",
									"    }",
									"    ",
									"    const addresses = res.json();",
									"    if (addresses && addresses.length > 0) {",
									"        const testAddress = addresses[0];",
									"        pm.collectionVariables.set('testAddressId', testAddress.address_id);",
									"        pm.collectionVariables.set('testAddressCity', testAddress.city || 'Buenos Aires');",
									"        pm.collectionVariables.set('testAddressCountry', testAddress.country_name || 'Argentina');",
									"        console.log('Found test address:', testAddress.address_id);",
									"    } else {",
									"        console.warn('No addresses found - tests may fail');",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Query successful\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"At least one address exists\", function () {",
									"    const addresses = pm.response.json();",
									"    pm.expect(addresses).to.be.an('array');",
									"    pm.expect(addresses.length).to.be.above(0);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{adminAuthToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/addresses",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "addresses"]
						}
					}
				},
				{
					"name": "Fetch Address (verify geolocation created)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Response successful\", function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
									"});",
									"",
									"if (pm.response.code === 200) {",
									"    pm.test(\"Address has expected fields\", function () {",
									"        const body = pm.response.json();",
									"        pm.expect(body).to.have.property('address_id');",
									"        pm.expect(body).to.have.property('city');",
									"        pm.expect(body).to.have.property('country_code');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{adminAuthToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/addresses/{{testAddressId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "addresses", "{{testAddressId}}"]
						}
					}
				}
			]
		},
		{
			"name": "Provider Verification",
			"item": [
				{
					"name": "Verify Provider Configuration",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Health check passes\", function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
									"});",
									"",
									"console.log('Geolocation Testing Notes:');",
									"console.log('1. ADDRESS_PROVIDER=mapbox (default) uses Mapbox Geocoding API v6');",
									"console.log('2. ADDRESS_PROVIDER=google uses Google Maps Geocoding API (fallback)');",
									"console.log('3. DEV_MODE=true uses mock responses (no API costs)');",
									"console.log('4. If Mapbox token is set, DEV_MODE is overridden to use live API');",
									"console.log('');",
									"console.log('Mock files:');",
									"console.log('  Mapbox: app/mocks/mapbox_geocoding_mocks.json');",
									"console.log('  Google: app/mocks/google_maps_responses.json');",
									"console.log('');",
									"console.log('Check server logs for:');",
									"console.log('  \"Mapbox Geocoding API Gateway running in DEV_MODE\" (mock)');",
									"console.log('  \"Mapbox Geocoding Gateway using live API\" (live)');",
									"console.log('  \"External API Call: Mapbox Geocoding API...\" (API call logged)');"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{adminAuthToken}}"
							}
						],
						"url": "{{baseUrl}}/api/v1/health"
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8000",
			"type": "string"
		},
		{
			"key": "superAdminUsername",
			"value": "",
			"type": "string",
			"description": "Set by environment variable"
		},
		{
			"key": "superAdminPassword",
			"value": "",
			"type": "string",
			"description": "Set by environment variable"
		},
		{
			"key": "authToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "adminAuthToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "testAddressId",
			"value": "",
			"type": "string",
			"description": "Automatically populated by query"
		},
		{
			"key": "testAddressCity",
			"value": "",
			"type": "string",
			"description": "Automatically populated by query"
		},
		{
			"key": "testAddressCountry",
			"value": "",
			"type": "string",
			"description": "Automatically populated by query"
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{authToken}}",
				"type": "string"
			}
		]
	}
}
