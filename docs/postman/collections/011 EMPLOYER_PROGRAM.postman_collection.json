                "employer",
                "billing"
              ]
            }
          }
        },
        {
          "name": "5.2 Run Billing Cron",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Cron ran successfully', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const body = pm.response.json();",
                  "    console.log('Billing cron result:', JSON.stringify(body));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/employer/billing/run-cron",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "employer",
                "billing",
                "run-cron"
              ]
            }
          }
        }
