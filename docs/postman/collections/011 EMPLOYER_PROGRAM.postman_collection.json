      ]
    },
    {
      "name": "4 Employee Management",
      "item": [
        {
          "name": "4.1 Enroll Single Employee",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Accept 201 (new employee) or 409 (email already registered from prior run).",
                  "// On 409, fetch employee list to get the existing user_id.",
                  "if (pm.response.code === 201) {",
                  "    pm.test('Employee enrolled - Status 201', function () {",
                  "        pm.response.to.have.status(201);",
                  "        const body = pm.response.json();",
                  "        pm.expect(body).to.have.property('user_id');",
                  "        pm.expect(body.email).to.equal('employee1@postman-employer.com');",
                  "        pm.environment.set('employeeUserId', body.user_id);",
                  "        console.log('Employee enrolled:', body.user_id);",
                  "    });",
                  "} else if (pm.response.code === 409) {",
                  "    // Employee already exists \u2014 fetch list to get user_id.",
                  "    // Use employerToken (set in 2.5) since this endpoint requires employer/internal auth.",
                  "    const token = pm.environment.get('employerToken') || pm.collectionVariables.get('employerToken')",
                  "        || pm.environment.get('authToken') || pm.collectionVariables.get('authToken');",
                  "    const baseUrl = pm.environment.get('baseUrl') || pm.variables.get('baseUrl');",
                  "    pm.sendRequest({",
                  "        url: baseUrl + '/api/v1/employer/employees',",
                  "        method: 'GET',",
                  "        header: { 'Authorization': 'Bearer ' + token }",
                  "    }, function(err, res) {",
                  "        pm.test('Employee enrolled - Status 201', function () {",
                  "            if (err || res.code !== 200) {",
                  "                pm.expect.fail('409 and could not list employees: ' + (err || res.code) + ' ' + (res && res.text ? res.text() : ''));",
                  "                return;",
                  "            }",
                  "            const employees = res.json();",
                  "            const existing = Array.isArray(employees)",
                  "                ? employees.find(e => e.email === 'employee1@postman-employer.com')",
                  "                : null;",
                  "            if (!existing) {",
                  "                pm.expect.fail('409 but employee1@postman-employer.com not found in GET /employer/employees');",
                  "                return;",
                  "            }",
                  "            pm.environment.set('employeeUserId', existing.user_id);",
                  "            console.log('Employee already enrolled (idempotent re-run):', existing.user_id);",
                  "            pm.expect(true).to.equal(true);",
                  "        });",
                  "    });",
                  "} else {",
                  "    pm.test('Employee enrolled - Status 201', function () {",
                  "        pm.expect.fail('Unexpected: ' + pm.response.code + ' - ' + pm.response.text());",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{employerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"employee1@postman-employer.com\",\n    \"first_name\": \"Test\",\n    \"last_name\": \"Employee\",\n    \"city_metadata_id\": \"{{cityMetadataId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/employer/employees",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "employer",
                "employees"
              ]
            }
          }
        },
        {
          "name": "4.2 List Enrolled Employees",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Employees listed', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.be.an('array').with.length.at.least(1);",
                  "    pm.expect(body[0]).to.have.property('user_id');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{employerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/employer/employees",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "employer",
                "employees"
              ]
            }
          }
        },
        {
          "name": "4.3 Subscribe Employee to Plan",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Employee subscribed', function () {",
                  "    const status = pm.response.code;",
                  "    pm.expect(status).to.be.oneOf([201, 400]);",
                  "    if (status === 201) {",
                  "        console.log('Employee subscribed to plan');",
                  "    } else {",
                  "        const d = pm.response.json().detail; console.log('Subscription result:', (d && d.message) || d);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{employerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"plan_id\": \"{{planId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/employer/employees/{{employeeUserId}}/subscribe",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "employer",
                "employees",
                "{{employeeUserId}}",
                "subscribe"
              ]
            }
          }
        }
      ]
