{
  "info": {
    "_postman_id": "011-employer-program-v2",
    "name": "011 EMPLOYER_PROGRAM",
    "description": "Employer Benefits Program E2E: multinational institution model. Creates employer institution with market_ids, creates entity (with email_domain, tax_id, currency), configures benefits program (institution-level), enrolls employees, subscribes, generates bills per entity. Depends on: Super Admin credentials, at least one market + plan in DB (run collection 000 first or seed DB).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1 Auth & Setup",
      "item": [
        {
          "name": "1.1 Login Super Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login successful', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('access_token');",
                  "    pm.environment.set('adminToken', body.access_token);",
                  "    pm.environment.set('adminUserId', body.user_id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "superadmin"
                },
                {
                  "key": "password",
                  "value": "SuperAdmin1"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "token"
              ]
            }
          }
        },
        {
          "name": "1.2 Get Market + Plan IDs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Markets found', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const body = pm.response.json();",
                  "    const market = body.find(m => m.country_code === 'AR') || body.find(m => m.country_code !== 'XG') || body[0];",
                  "    pm.expect(market).to.not.be.undefined;",
                  "    pm.environment.set('marketId', market.market_id);",
                  "    pm.environment.set('marketCountryCode', market.country_code);",
                  "    pm.environment.set('currencyMetadataId', market.currency_metadata_id);",
                  "    console.log('Using market:', market.country_code, market.market_id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/markets/enriched",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "markets",
                "enriched"
              ]
            }
          }
        },
        {
          "name": "1.3 Get Plan for Market",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Plan found', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const body = pm.response.json();",
                  "    const plan = body.find(p => !p.is_archived) || body[0];",
                  "    if (plan) {",
                  "        pm.environment.set('planId', plan.plan_id);",
                  "        pm.environment.set('planPrice', plan.price);",
                  "        console.log('Using plan:', plan.plan_id, 'price:', plan.price);",
                  "    } else {",
                  "        console.warn('No plan found \u2014 billing tests will fail');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/plans?market_id={{marketId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "plans"
              ],
              "query": [
                {
                  "key": "market_id",
                  "value": "{{marketId}}"
                }
              ]
            }
          }
        },
        {
          "name": "1.4 Resolve City Metadata",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('City found', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const body = pm.response.json();",
                  "    const city = body[0];",
                  "    if (city) {",
                  "        pm.environment.set('cityMetadataId', city.city_metadata_id);",
                  "        console.log('Using city:', city.city_metadata_id);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/cities?country_code={{marketCountryCode}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "cities"
              ],
              "query": [
                {
                  "key": "country_code",
                  "value": "{{marketCountryCode}}"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2 Employer Institution + Entity",
      "item": [
        {
          "name": "2.1 Upsert Canonical Employer Institution (idempotent)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// PUT /institutions/by-key returns 200 on both insert and update",
                  "const body = pm.response.json();",
                  "if (body.institution_id) {",
                  "    pm.environment.set('employerInstitutionId', body.institution_id);",
                  "    console.log('Employer institution:', body.institution_id);",
                  "}",
                  "",
                  "pm.test('Upsert Employer Institution - Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Has institution_id and market_ids', function () {",
                  "    pm.expect(body).to.have.property('institution_id');",
                  "    pm.expect(body).to.have.property('market_ids');",
                  "    pm.expect(body.market_ids).to.be.an('array').with.length.at.least(1);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"canonical_key\": \"E2E_INSTITUTION_EMPLOYER_011\",\n    \"name\": \"Postman Employer Corp\",\n    \"institution_type\": \"employer\",\n    \"market_ids\": [\"{{marketId}}\"]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/institutions/by-key",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "institutions",
                "by-key"
              ]
            }
          }
        },
