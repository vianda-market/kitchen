                  "pm.collectionVariables.set('employerAdminUsername', 'employer_admin_011_' + suffix);",
                  "pm.collectionVariables.set('employerAdminEmail', 'employer_admin_011_' + suffix + '@postman-test.com');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('User created - Status 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('user_id');",
                  "    pm.environment.set('employerAdminUserId', body.user_id);",
