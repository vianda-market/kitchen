    {
      "name": "3 Program Config",
      "item": [
        {
          "name": "3.1 Upsert Canonical Benefits Program (idempotent)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// PUT /employer/program/by-key returns 200 on both insert and update",
                  "pm.test('Upsert Benefits Program - Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('program_id');",
                  "    pm.expect(body.benefit_rate).to.equal(70);",
                  "    pm.environment.set('programId', body.program_id);",
