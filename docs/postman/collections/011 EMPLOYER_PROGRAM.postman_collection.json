{
  "info": {
    "_postman_id": "011-employer-program-v2",
    "name": "011 EMPLOYER_PROGRAM",
    "description": "Employer Benefits Program E2E: multinational institution model. Creates employer institution with market_ids, creates entity (with email_domain, tax_id, currency), configures benefits program (institution-level), enrolls employees, subscribes, generates bills per entity. Depends on: Super Admin credentials, at least one market + plan in DB (run collection 000 first or seed DB).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1 Auth & Setup",
      "item": [
        {
          "name": "1.1 Login Super Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login successful', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('access_token');",
                  "    pm.environment.set('adminToken', body.access_token);",
                  "    pm.environment.set('adminUserId', body.user_id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "superadmin"
                },
                {
                  "key": "password",
                  "value": "SuperAdmin1"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "token"
              ]
            }
          }
        },
        {
          "name": "1.2 Get Market + Plan IDs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Markets found', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const body = pm.response.json();",
                  "    const market = body.find(m => m.country_code === 'AR') || body.find(m => m.country_code !== 'XG') || body[0];",
                  "    pm.expect(market).to.not.be.undefined;",
                  "    pm.environment.set('marketId', market.market_id);",
                  "    pm.environment.set('marketCountryCode', market.country_code);",
                  "    pm.environment.set('currencyMetadataId', market.currency_metadata_id);",
                  "    console.log('Using market:', market.country_code, market.market_id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/markets/enriched",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "markets",
                "enriched"
              ]
            }
          }
        },
        {
          "name": "1.3 Get Plan for Market",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Plan found', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const body = pm.response.json();",
                  "    const plan = body.find(p => !p.is_archived) || body[0];",
                  "    if (plan) {",
                  "        pm.environment.set('planId', plan.plan_id);",
                  "        pm.environment.set('planPrice', plan.price);",
                  "        console.log('Using plan:', plan.plan_id, 'price:', plan.price);",
                  "    } else {",
                  "        console.warn('No plan found — billing tests will fail');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/plans?market_id={{marketId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "plans"
              ],
              "query": [
                {
                  "key": "market_id",
                  "value": "{{marketId}}"
                }
              ]
            }
          }
        },
        {
          "name": "1.4 Resolve City Metadata",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('City found', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const body = pm.response.json();",
                  "    const city = body[0];",
                  "    if (city) {",
                  "        pm.environment.set('cityMetadataId', city.city_metadata_id);",
                  "        console.log('Using city:', city.city_metadata_id);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/cities?country_code={{marketCountryCode}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "cities"
              ],
              "query": [
                {
                  "key": "country_code",
                  "value": "{{marketCountryCode}}"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2 Employer Institution + Entity",
      "item": [
        {
          "name": "2.1 Create Employer Institution",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Save variables FIRST (outside test blocks) so downstream steps always have them",
                  "const body = pm.response.json();",
                  "if (body.institution_id) {",
                  "    pm.environment.set('employerInstitutionId', body.institution_id);",
                  "    console.log('Employer institution:', body.institution_id);",
                  "}",
                  "",
                  "pm.test('Institution created - Status 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Has institution_id and market_ids', function () {",
                  "    pm.expect(body).to.have.property('institution_id');",
                  "    pm.expect(body).to.have.property('market_ids');",
                  "    pm.expect(body.market_ids).to.be.an('array').with.length.at.least(1);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Postman Employer Corp\",\n    \"institution_type\": \"employer\",\n    \"market_ids\": [\"{{marketId}}\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/institutions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "institutions"
              ]
            }
          }
        },
        {
          "name": "2.2 Create Employer Admin User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Unique username per run to avoid 'Username already exists' across reruns",
                  "const suffix = Date.now();",
                  "pm.collectionVariables.set('employerAdminUsername', 'employer_admin_011_' + suffix);",
                  "pm.collectionVariables.set('employerAdminEmail', 'employer_admin_011_' + suffix + '@postman-test.com');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('User created - Status 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('user_id');",
                  "    pm.environment.set('employerAdminUserId', body.user_id);",
                  "    console.log('Employer admin user:', body.user_id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"{{employerAdminUsername}}\",\n    \"email\": \"{{employerAdminEmail}}\",\n    \"password\": \"Employer123!\",\n    \"role_type\": \"employer\",\n    \"role_name\": \"admin\",\n    \"institution_id\": \"{{employerInstitutionId}}\",\n    \"market_id\": \"{{marketId}}\",\n    \"city_metadata_id\": \"{{cityMetadataId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users"
              ]
            }
          }
        },
        {
          "name": "2.3 Create Address for Entity",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Address created - Status 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('address_id');",
                  "    pm.environment.set('entityAddressId', body.address_id);",
                  "    console.log('Entity address:', body.address_id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"institution_id\": \"{{employerInstitutionId}}\",\n    \"country_code\": \"{{marketCountryCode}}\",\n    \"province\": \"Buenos Aires\",\n    \"city\": \"Buenos Aires\",\n    \"postal_code\": \"C1001\",\n    \"street_type\": \"ave\",\n    \"street_name\": \"Corrientes\",\n    \"building_number\": \"500\",\n    \"city_metadata_id\": \"{{cityMetadataId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/addresses",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "addresses"
              ]
            }
          }
        },
        {
          "name": "2.4 Create Employer Entity (with email_domain)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Entity created - Status 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('institution_entity_id');",
                  "    pm.expect(body.email_domain).to.equal('postman-employer.com');",
                  "    pm.environment.set('employerEntityId', body.institution_entity_id);",
                  "    console.log('Employer entity:', body.institution_entity_id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"institution_id\": \"{{employerInstitutionId}}\",\n    \"address_id\": \"{{entityAddressId}}\",\n    \"tax_id\": \"30123456789\",\n    \"name\": \"Postman Employer AR S.A.\",\n    \"email_domain\": \"postman-employer.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/institution-entities",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "institution-entities"
              ]
            }
          }
        },
        {
          "name": "2.5 Login Employer Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login successful', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('access_token');",
                  "    pm.environment.set('employerToken', body.access_token);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "{{employerAdminUsername}}"
                },
                {
                  "key": "password",
                  "value": "Employer123!"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "token"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "3 Program Config",
      "item": [
        {
          "name": "3.1 Create Benefits Program (institution-level defaults)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Program created - Status 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('program_id');",
                  "    pm.expect(body.benefit_rate).to.equal(70);",
                  "    pm.expect(body.institution_entity_id).to.be.null;",
                  "    pm.environment.set('programId', body.program_id);",
                  "    console.log('Program (institution-level):', body.program_id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"institution_id\": \"{{employerInstitutionId}}\",\n    \"benefit_rate\": 70,\n    \"benefit_cap_period\": \"monthly\",\n    \"price_discount\": 10,\n    \"billing_cycle\": \"monthly\",\n    \"enrollment_mode\": \"managed\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/employer/program",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "employer",
                "program"
              ]
            }
          }
        },
        {
          "name": "3.2 Get Benefits Program",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Program retrieved', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.benefit_rate).to.equal(70);",
                  "    pm.expect(body.price_discount).to.equal(10);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{employerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/employer/program",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "employer",
                "program"
              ]
            }
          }
        },
        {
          "name": "3.3 Update Benefits Program",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Program updated', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.benefit_rate).to.equal(80);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"benefit_rate\": 80\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/employer/program?institution_id={{employerInstitutionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "employer",
                "program"
              ],
              "query": [
                {
                  "key": "institution_id",
                  "value": "{{employerInstitutionId}}"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "4 Employee Management",
      "item": [
        {
          "name": "4.1 Enroll Single Employee",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Employee enrolled - Status 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('user_id');",
                  "    pm.expect(body.email).to.equal('employee1@postman-employer.com');",
                  "    pm.environment.set('employeeUserId', body.user_id);",
                  "    console.log('Employee enrolled:', body.user_id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{employerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"employee1@postman-employer.com\",\n    \"first_name\": \"Test\",\n    \"last_name\": \"Employee\",\n    \"city_metadata_id\": \"{{cityMetadataId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/employer/employees",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "employer",
                "employees"
              ]
            }
          }
        },
        {
          "name": "4.2 List Enrolled Employees",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Employees listed', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.be.an('array').with.length.at.least(1);",
                  "    pm.expect(body[0]).to.have.property('user_id');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{employerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/employer/employees",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "employer",
                "employees"
              ]
            }
          }
        },
        {
          "name": "4.3 Subscribe Employee to Plan",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Employee subscribed', function () {",
                  "    const status = pm.response.code;",
                  "    pm.expect(status).to.be.oneOf([201, 400]);",
                  "    if (status === 201) {",
                  "        console.log('Employee subscribed to plan');",
                  "    } else {",
                  "        const d = pm.response.json().detail; console.log('Subscription result:', (d && d.message) || d);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{employerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"plan_id\": \"{{planId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/employer/employees/{{employeeUserId}}/subscribe",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "employer",
                "employees",
                "{{employeeUserId}}",
                "subscribe"
              ]
            }
          }
        }
      ]
    },
