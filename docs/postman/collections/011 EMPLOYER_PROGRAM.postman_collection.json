        },
        {
          "name": "2.4 Upsert Canonical Employer Entity (idempotent)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// PUT /institution-entities/by-key returns 200 on both insert and update",
                  "pm.test('Upsert Employer Entity - Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('institution_entity_id');",
                  "    pm.expect(body.email_domain).to.equal('postman-employer.com');",
                  "    pm.environment.set('employerEntityId', body.institution_entity_id);",
                  "    console.log('Employer entity:', body.institution_entity_id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// PUT /institution-entities/by-key is Internal-only. Use the super admin authToken.",
                  "const token = pm.environment.get('authToken') || pm.collectionVariables.get('authToken');",
                  "if (token) {",
                  "    pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + token });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"canonical_key\": \"E2E_INSTITUTION_ENTITY_EMPLOYER_011\",\n    \"institution_id\": \"{{employerInstitutionId}}\",\n    \"address_id\": \"{{entityAddressId}}\",\n    \"tax_id\": \"30123456789\",\n    \"name\": \"Postman Employer AR S.A.\",\n    \"email_domain\": \"postman-employer.com\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/institution-entities/by-key",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "institution-entities",
                "by-key"
              ]
            }
          }
        },
        {
          "name": "2.5 Login Employer Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login successful', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('access_token');",
                  "    pm.environment.set('employerToken', body.access_token);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
