          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 304 Not Modified', () => pm.response.to.have.status(304));",
                  "pm.test('Body is empty on 304', () => pm.expect(pm.response.text()).to.have.lengthOf(0));",
                  "const etag = pm.response.headers.get('ETag');",
                  "const priorEtag = pm.collectionVariables.get('countriesEtagEn');",
                  "pm.test('ETag preserved on 304', () => pm.expect(etag).to.equal(priorEtag));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "If-None-Match", "value": "{{countriesEtagEn}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/leads/countries?language=en",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "leads", "countries"],
              "query": [{ "key": "language", "value": "en" }]
            },
            "description": "Revalidation. Requires the prior 'en' request to have populated countriesEtagEn."
          }
        },
