                  "    const code = pm.response.code;",
                  "    pm.expect([200, 404]).to.include(code);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.test('Response has restaurant_count and has_coverage', function () {",
                  "        pm.expect(body).to.have.property('restaurant_count');",
                  "        pm.expect(body).to.have.property('has_coverage');",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/leads/zipcode-metrics?zip=10001",
