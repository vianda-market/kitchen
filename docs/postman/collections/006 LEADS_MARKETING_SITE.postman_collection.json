    {
      "name": "Country selectors (no auth, no reCAPTCHA)",
      "item": [
        {
          "name": "GET /leads/countries (en) \u2014 happy path + ETag + Cache-Control",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('No recaptcha token required (token header was not sent)', () => { /* documented */ });",
                  "",
                  "const cc = pm.response.headers.get('Cache-Control') || '';",
                  "pm.test('Cache-Control is public, max-age=86400, stale-while-revalidate=3600', () => {",
                  "    pm.expect(cc).to.include('public');",
                  "    pm.expect(cc).to.include('max-age=86400');",
                  "    pm.expect(cc).to.include('stale-while-revalidate=3600');",
                  "});",
                  "",
                  "const etag = pm.response.headers.get('ETag');",
                  "pm.test('ETag header is present', () => pm.expect(etag).to.be.a('string').and.not.empty);",
                  "if (etag) {",
                  "    pm.collectionVariables.set('countriesEtagEn', etag);",
                  "}",
                  "",
                  "const body = pm.response.json();",
                  "pm.test('Response is a JSON array', () => pm.expect(body).to.be.an('array'));",
                  "",
                  "if (body.length > 0) {",
                  "    const first = body[0];",
                  "    pm.test('Rows include code/name/currency/phone_prefix/default_locale', () => {",
                  "        pm.expect(first).to.have.property('code');",
                  "        pm.expect(first).to.have.property('name');",
                  "        pm.expect(first).to.have.property('currency');",
                  "        pm.expect(first).to.have.property('phone_prefix');",
                  "        pm.expect(first).to.have.property('default_locale');",
                  "    });",
                  "    pm.test('default_locale is en|es|pt', () => pm.expect(['en','es','pt']).to.include(first.default_locale));",
                  "    pm.collectionVariables.set('firstActiveCountryCode', first.code);",
                  "} else {",
                  "    console.log('Empty /leads/countries \u2014 frontend contract: hide navbar selector + country-scoped sections');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/leads/countries?language=en",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "leads", "countries"],
              "query": [{ "key": "language", "value": "en" }]
            },
            "description": "Customer-facing country selector source. Markets with status='active'. No reCAPTCHA token required \u2014 this is a navbar-load fetch."
          }
        },
