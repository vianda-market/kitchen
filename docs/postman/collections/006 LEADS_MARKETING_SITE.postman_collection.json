    {
      "name": "Admin override on market status (guardrails)",
      "description": "Exercises the admin override validation added to PUT /admin/markets/{id}. Requires a super admin token and at least one non-global market in the DB.",
      "item": [
        {
          "name": "Login Super Admin (idempotent)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Skip when a token is already provided via Newman --globals or set by a prior run.",
                  "const existing = pm.globals.get('superAdminAuthToken') || pm.collectionVariables.get('superAdminAuthToken');",
                  "if (existing && String(existing).length > 0) {",
                  "    pm.collectionVariables.set('superAdminAuthToken', existing);",
                  "    console.log('superAdminAuthToken already set \u2014 skipping login.');",
                  "    postman.setNextRequest('Discover a non-global market + its coverage status');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const response = pm.response.json();",
                  "pm.test('Response has access_token', () => pm.expect(response).to.have.property('access_token'));",
                  "const token = response.access_token;",
                  "pm.collectionVariables.set('superAdminAuthToken', token);",
                  "pm.environment.set('superAdminAuthToken', token);",
                  "pm.globals.set('superAdminAuthToken', token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "{{superAdminUsername}}" },
                { "key": "password", "value": "{{superAdminPassword}}" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/token",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "token"]
            },
            "description": "Skipped when superAdminAuthToken already exists as a Postman global. See docs/postman/guidelines/LEADS_COLLECTION_CONVENTIONS.md for the seed-collection / Newman --globals pattern."
          }
        },
        {
          "name": "Discover a non-global market + its coverage status",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const markets = pm.response.json();",
                  "pm.test('Returned list of markets', () => pm.expect(markets).to.be.an('array').and.not.empty);",
                  "",
                  "const GLOBAL = '00000000-0000-0000-0000-000000000001';",
                  "const target = markets.find(m => m.market_id !== GLOBAL);",
                  "pm.test('Found a non-global market', () => pm.expect(target).to.exist);",
                  "",
                  "if (target) {",
                  "    pm.collectionVariables.set('testMarketId', target.market_id);",
                  "    pm.collectionVariables.set('testMarketStatus', target.status);",
                  "    pm.collectionVariables.set('testMarketCountry', target.country_code);",
                  "    console.log('Target market:', target.country_code, target.market_id, 'status:', target.status);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{superAdminAuthToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/markets",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "markets"]
            }
          }
        },
        {
          "name": "PUT /admin/markets/{id} status=active \u2014 expect 400 when market has no coverage OR 200 if it does",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 400', () => pm.expect([200, 400]).to.include(pm.response.code));",
                  "",
                  "if (pm.response.code === 400) {",
                  "    const body = pm.response.json();",
                  "    pm.test('400 detail mentions Cannot activate', () => pm.expect(String(body.detail || '')).to.include('Cannot activate'));",
                  "    pm.test('400 detail explains coverage requirement', () => pm.expect(String(body.detail || '')).to.match(/plate|coverage|kitchen-day/));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{superAdminAuthToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/markets/{{testMarketId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "markets", "{{testMarketId}}"]
            },
            "description": "Admin guardrail: `status='active'` is refused when the market has no active restaurant \u2192 plate \u2192 plate_kitchen_days chain. The 30-day forward window tightening is deferred to the cron (`docs/plans/market-status-cron.md`)."
          }
        },
        {
          "name": "PUT /admin/markets/{id} status=inactive (no confirm) \u2014 409 if coverage, 200 otherwise",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 409', () => pm.expect([200, 409]).to.include(pm.response.code));",
                  "",
                  "if (pm.response.code === 409) {",
                  "    const body = pm.response.json();",
                  "    pm.test('409 detail mentions active plate coverage', () => pm.expect(String(body.detail || '')).to.match(/active plate coverage|confirm_deactivate/));",
                  "    pm.test('409 detail names confirm_deactivate as the unlock', () => pm.expect(String(body.detail || '')).to.include('confirm_deactivate'));",
                  "    pm.collectionVariables.set('marketHasCoverage', 'true');",
                  "} else {",
                  "    pm.collectionVariables.set('marketHasCoverage', 'false');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{superAdminAuthToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"inactive\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/markets/{{testMarketId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "markets", "{{testMarketId}}"]
            },
            "description": "Deactivation warning: when the market has active plate coverage, the backend refuses without `confirm_deactivate: true`."
          }
        },
        {
          "name": "PUT /admin/markets/{id} status=inactive + confirm_deactivate=true \u2014 200",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Returned market status is inactive', () => pm.expect(body.status).to.eql('inactive'));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{superAdminAuthToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"inactive\",\n  \"confirm_deactivate\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/markets/{{testMarketId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "markets", "{{testMarketId}}"]
            },
            "description": "Deactivation succeeds when the second-confirm flag is set."
          }
        },
        {
          "name": "Restore original market status",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 400', () => pm.expect([200, 400]).to.include(pm.response.code));",
                  "if (pm.response.code === 400) {",
                  "    console.warn('Could not restore original status \u2014 likely the admin-activation guardrail fired. Market left inactive.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{superAdminAuthToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"{{testMarketStatus}}\",\n  \"confirm_deactivate\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/markets/{{testMarketId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "markets", "{{testMarketId}}"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000", "type": "string" },
    { "key": "sampleZip", "value": "10001", "type": "string" },
    { "key": "sampleCountryCode", "value": "US", "type": "string" },
    { "key": "superAdminUsername", "value": "superadmin", "type": "string" },
    { "key": "superAdminPassword", "value": "SuperAdmin1", "type": "string" },
    { "key": "superAdminAuthToken", "value": "", "type": "string", "description": "Set by Login Super Admin, or pre-seeded via Newman --globals." },
    { "key": "recaptchaToken", "value": "dev-bypass", "type": "string", "description": "Canonical name across all leads collections. Any non-empty string when RECAPTCHA_SECRET_KEY is empty locally (verify_recaptcha short-circuits); real reCAPTCHA v3 token in staging/prod." },
    { "key": "countriesEtagEn", "value": "", "type": "string", "description": "Captured from the first /leads/countries?language=en call; reused by the 304 test." },
    { "key": "firstActiveCountryCode", "value": "", "type": "string", "description": "First country code returned by /leads/countries \u2014 used to assert /leads/supplier-countries is a superset." },
    { "key": "testMarketId", "value": "", "type": "string", "description": "Non-global market UUID discovered at run time." },
    { "key": "testMarketStatus", "value": "", "type": "string", "description": "Original status captured before mutation; restored at the end." },
    { "key": "testMarketCountry", "value": "", "type": "string" },
    { "key": "marketHasCoverage", "value": "", "type": "string", "description": "'true' | 'false' \u2014 inferred from whether the unconfirmed deactivation returned 409." }
  ]
}
