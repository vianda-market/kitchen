{
	"info": {
		"_postman_id": "enum-service-api-2026",
		"name": "003 ENUM_SERVICE",
		"description": "003 – Run after 000 (customer: customer/Customer123!) and 002 (admin: admin/Admin123!). Uses env customerUsername/customerPassword and adminUsername/adminPassword or collection defaults. Test collection for the Enum Service API.",
		"schema": "https://schema.getpostman.com/json/collection/v2.0.0/collection.json"
	},
	"item": [
		{
			"name": "🔐 Authentication",
			"item": [
				{
					"name": "Login as Vianda Admin (Employee)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"const response = pm.response.json();",
									"pm.test('Response has access_token', function () {",
									"    pm.expect(response).to.have.property('access_token');",
									"});",
									"",
									"pm.collectionVariables.set('adminAuthToken', response.access_token);",
									"pm.environment.set('authToken', response.access_token);",
									"pm.environment.set('adminAuthToken', response.access_token);",
									"pm.globals.set('adminAuthToken', response.access_token);",
									"pm.globals.set('authToken', response.access_token);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "username",
									"value": "{{adminUsername}}"
								},
								{
									"key": "password",
									"value": "{{adminPassword}}"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/token",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "token"]
						}
					}
				},
				{
					"name": "Login as Customer",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"const response = pm.response.json();",
									"pm.test('Response has access_token', function () {",
									"    pm.expect(response).to.have.property('access_token');",
									"});",
									"",
									"pm.collectionVariables.set('customerAuthToken', response.access_token);",
									"pm.environment.set('customerAuthToken', response.access_token);",
									"pm.globals.set('customerAuthToken', response.access_token);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "username",
									"value": "{{customerUsername}}"
								},
								{
									"key": "password",
									"value": "{{customerPassword}}"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/token",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "token"]
						}
					}
				}
			]
		},
		{
			"name": "📊 Enum Service Tests",
			"item": [
				{
					"name": "Get All Enums",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"const response = pm.response.json();",
									"",
									"pm.test('Response is an object', function () {",
									"    pm.expect(response).to.be.an('object');",
									"});",
									"",
									"// Test that all expected enum types are present",
									"const expectedEnumTypes = [",
									"    'status', 'address_type', 'role_type', 'role_name',",
									"    'subscription_status', 'method_type',",
									"    'transaction_type', 'street_type', 'kitchen_day',",
									"    'pickup_type', 'discretionary_reason', 'bill_resolution'",
									"];",
									"",
									"expectedEnumTypes.forEach(enumType => {",
									"    pm.test(`Response has ${enumType} enum`, function () {",
									"        pm.expect(response).to.have.property(enumType);",
									"        pm.expect(response[enumType]).to.be.an('array');",
									"        pm.expect(response[enumType].length).to.be.greaterThan(0);",
									"    });",
									"});",
									"",
									"// Test cache headers",
									"pm.test('Response has Cache-Control header', function () {",
									"    pm.expect(pm.response.headers.get('Cache-Control')).to.include('max-age');",
									"});",
									"",
									"pm.test('Response has X-Content-Type-Options header', function () {",
									"    pm.expect(pm.response.headers.get('X-Content-Type-Options')).to.equal('nosniff');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{adminAuthToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/enums",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "enums", ""]
						}
					}
				},
				{
					"name": "Get Status Enum",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"const response = pm.response.json();",
									"",
									"pm.test('Response is an array', function () {",
									"    pm.expect(response).to.be.an('array');",
									"    pm.expect(response.length).to.be.greaterThan(0);",
									"});",
									"",
									"pm.test('Status enum contains expected values', function () {",
									"    pm.expect(response).to.include('Active');",
									"    pm.expect(response).to.include('Inactive');",
									"    pm.expect(response).to.include('Pending');",
									"});",
									"",
									"pm.test('Response has Cache-Control header', function () {",
									"    pm.expect(pm.response.headers.get('Cache-Control')).to.include('max-age');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{adminAuthToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/enumsstatus",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "enums", "status"]
						}
					}
				},
				{
					"name": "Get Subscription Status Enum",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"const response = pm.response.json();",
									"",
									"pm.test('Response is an array', function () {",
									"    pm.expect(response).to.be.an('array');",
									"});",
									"",
									"pm.test('Subscription status enum contains expected values', function () {",
									"    pm.expect(response).to.include('Active');",
									"    pm.expect(response).to.include('On Hold');",
									"    pm.expect(response).to.include('Pending');",
									"    pm.expect(response).to.include('Cancelled');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{adminAuthToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/enumssubscription_status",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "enums", "subscription_status"]
						}
					}
				},
				{
					"name": "Get Role Type Enum",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"const response = pm.response.json();",
									"",
									"pm.test('Role type enum contains expected values', function () {",
									"    pm.expect(response).to.include('Employee');",
									"    pm.expect(response).to.include('Supplier');",
									"    pm.expect(response).to.include('Customer');",
									"    pm.expect(response.length).to.equal(3);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{adminAuthToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/enumsrole_type",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "enums", "role_type"]
						}
					}
				},
				{
					"name": "Customer Can Access Enums",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Sync customer token: prefer collection (from 003 Login as Customer), else pull from env/globals (000).",
									"const collCust = pm.collectionVariables.get('customerAuthToken');",
									"if (!collCust) {",
									"    const ct = pm.environment.get('customerAuthToken') || pm.globals.get('customerAuthToken') || pm.environment.get('clientUserAuthToken') || pm.globals.get('clientUserAuthToken');",
									"    if (ct) pm.collectionVariables.set('customerAuthToken', ct);",
									"}"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Customer can access enums', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"const response = pm.response.json();",
									"",
									"pm.test('Response contains all enum types', function () {",
									"    pm.expect(response).to.have.property('status');",
									"    pm.expect(response).to.have.property('subscription_status');",
									"    pm.expect(response).to.have.property('address_type');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{customerAuthToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/enums",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "enums", ""]
						}
					}
				}
			]
		},
		{
