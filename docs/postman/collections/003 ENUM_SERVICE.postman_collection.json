  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// Use admin from 001/002 (env or globals) when available",
          "const u = pm.environment.get('adminUsername') || pm.globals.get('adminUsername');",
          "if (u) pm.collectionVariables.set('adminUsername', u);",
          "const p = pm.environment.get('adminPassword') || pm.globals.get('adminPassword');",
          "if (p) pm.collectionVariables.set('adminPassword', p);",
          "const t = pm.environment.get('adminAuthToken') || pm.globals.get('adminAuthToken');",
          "if (t) pm.collectionVariables.set('adminAuthToken', t);",
          "",
          "// Customer token: prefer 003's Login as Customer (collection) over stale env from 000.",
          "// Only pull from env/globals when collection has no token (avoids overwriting fresh with expired).",
          "const collCust = pm.collectionVariables.get('customerAuthToken');",
          "if (!collCust) {",
          "    const ct = pm.environment.get('customerAuthToken') || pm.globals.get('customerAuthToken') || pm.environment.get('clientUserAuthToken') || pm.globals.get('clientUserAuthToken');",
          "    if (ct) pm.collectionVariables.set('customerAuthToken', ct);",
          "}"
        ],
        "type": "text/javascript"
      }
    }
