    {
      "name": "📊 Enum Service Tests",
      "item": [
        {
          "name": "Get All Enums",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "",
                  "pm.test('Response is an object', function () {",
                  "    pm.expect(response).to.be.an('object');",
                  "});",
                  "",
                  "function assertLabeled(entry) {",
                  "    pm.expect(entry).to.have.property('values');",
                  "    pm.expect(entry).to.have.property('labels');",
                  "    pm.expect(entry.values).to.be.an('array');",
                  "    pm.expect(entry.labels).to.be.an('object');",
                  "    entry.values.forEach(v => pm.expect(entry.labels).to.have.property(v));",
                  "}",
                  "",
                  "// Test that all expected enum types are present (values + labels per key)",
                  "const expectedEnumTypes = [",
                  "    'status', 'address_type', 'role_type', 'role_name',",
                  "    'subscription_status', 'method_type',",
                  "    'transaction_type', 'street_type', 'kitchen_day',",
                  "    'pickup_type', 'discretionary_reason', 'bill_resolution'",
                  "];",
                  "",
                  "expectedEnumTypes.forEach(enumType => {",
                  "    pm.test(`Response has ${enumType} labeled enum`, function () {",
                  "        pm.expect(response).to.have.property(enumType);",
                  "        assertLabeled(response[enumType]);",
                  "        pm.expect(response[enumType].values.length).to.be.greaterThan(0);",
                  "    });",
                  "});",
                  "",
                  "// Test cache headers",
                  "pm.test('Response has Cache-Control header', function () {",
                  "    pm.expect(pm.response.headers.get('Cache-Control')).to.include('max-age');",
                  "});",
                  "",
                  "pm.test('Response has X-Content-Type-Options header', function () {",
                  "    pm.expect(pm.response.headers.get('X-Content-Type-Options')).to.equal('nosniff');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminAuthToken}}"
