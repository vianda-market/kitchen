		{
			"name": "Reference Data",
			"item": [
				{
					"name": "Get Supported Cuisines",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"const response = pm.response.json();",
									"pm.test('Response is array of cuisine objects', function () {",
									"    pm.expect(response).to.be.an('array');",
									"    pm.expect(response.length).to.be.greaterThan(0);",
									"    response.forEach(item => {",
									"        pm.expect(item).to.have.property('cuisine_name');",
									"    });",
									"});",
									"pm.test('Contains Italian, French, American', function () {",
									"    const names = response.map(r => r.cuisine_name);",
									"    pm.expect(names).to.include('Italian');",
									"    pm.expect(names).to.include('French');",
									"    pm.expect(names).to.include('American');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{adminAuthToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/cuisines",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "cuisines", ""]
						}
					}
				}
			]
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Set default values if not already set",
					"if (!pm.environment.get('baseUrl')) {",
					"    pm.environment.set('baseUrl', 'http://localhost:8000');",
					"}"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Global test for response time",
					"pm.test('Response time is less than 2000ms', function () {",
					"    pm.expect(pm.response.responseTime).to.be.below(2000);",
					"});",
					"",
					"// Global test for proper content type",
					"pm.test('Response has proper content type', function () {",
					"    if (pm.response.code !== 204) {",
					"        pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
					"    }",
					"});"
				]
			}
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"exec": [
"// Use admin from 001/002 (env or globals) when available",
									"const u = pm.environment.get('adminUsername') || pm.globals.get('adminUsername');",
									"if (u) pm.collectionVariables.set('adminUsername', u);",
									"const p = pm.environment.get('adminPassword') || pm.globals.get('adminPassword');",
									"if (p) pm.collectionVariables.set('adminPassword', p);",
									"const t = pm.environment.get('adminAuthToken') || pm.globals.get('adminAuthToken');",
									"if (t) pm.collectionVariables.set('adminAuthToken', t);",
									"",
									"// Customer token: prefer 003's Login as Customer (collection) over stale env from 000.",
									"// Only pull from env/globals when collection has no token (avoids overwriting fresh with expired).",
									"const collCust = pm.collectionVariables.get('customerAuthToken');",
									"if (!collCust) {",
									"    const ct = pm.environment.get('customerAuthToken') || pm.globals.get('customerAuthToken') || pm.environment.get('clientUserAuthToken') || pm.globals.get('clientUserAuthToken');",
									"    if (ct) pm.collectionVariables.set('customerAuthToken', ct);",
									"}"
				],
				"type": "text/javascript"
			}
		}
	],
