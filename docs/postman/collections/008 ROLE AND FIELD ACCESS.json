					}
				},
				{
					"name": "Institution create Supplier without no_show_discount – expect 422",
					"event": [{
						"listen": "test",
						"script": {
							"exec": [
								"pm.test('Status 422', function () { pm.response.to.have.status(422); });",
								"const r = pm.response.json();",
								"pm.test('Detail mentions no_show_discount', function () {",
								"    const d = r.detail;",
								"    const str = Array.isArray(d) ? d.map(function(x){ return (x&&x.msg)||JSON.stringify(x); }).join(' ') : (d||'');",
								"    pm.expect(str).to.match(/no_show_discount|Supplier/i);",
								"});"
							],
							"type": "text/javascript"
						}
					}],
					"request": {
						"method": "POST",
						"header": [
							{"key": "Authorization", "value": "Bearer {{adminToken}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Test Supplier No Discount\",\n  \"institution_type\": \"Supplier\",\n  \"market_id\": \"{{supplierInstitutionMarketId}}\"\n}"
						},
						"url": "{{baseUrl}}/api/v1/institutions/"
					}
				}
			]
		}
	]
