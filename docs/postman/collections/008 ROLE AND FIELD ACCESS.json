						},
						"url": "{{baseUrl}}/api/v1/addresses/"
					}
				}
			]
		},
		{
			"name": "User – Supplier",
			"item": [
				{
					"name": "User create – Supplier allowed (role_type Supplier)",
					"event": [{
						"listen": "test",
						"script": {
							"exec": [
								"pm.test('Status 201', function () { pm.response.to.have.status(201); });",
								"const r = pm.response.json();",
								"pm.test('Has user_id', function () { pm.expect(r).to.have.property('user_id'); });",
								"pm.test('Response role_type is Supplier', function () { pm.expect(r.role_type || '').to.eql('Supplier'); });"
							],
							"type": "text/javascript"
						}
					}],
					"request": {
						"method": "POST",
						"header": [
							{"key": "Authorization", "value": "Bearer {{supplierToken}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"institution_id\": \"{{supplierInstitutionId}}\",\n  \"role_type\": \"Supplier\",\n  \"role_name\": \"Admin\",\n  \"username\": \"newsupplier_{{$timestamp}}\",\n  \"email\": \"newsupplier_{{$timestamp}}@example.com\",\n  \"password\": \"TempPass123!\",\n  \"cellphone\": \"9999999999\",\n  \"first_name\": \"New\",\n  \"last_name\": \"Supplier\",\n  \"market_id\": \"{{supplierInstitutionMarketId}}\"\n}"
						},
						"url": "{{baseUrl}}/api/v1/users/"
					}
				},
				{
					"name": "User create – Supplier disallowed (role_type Customer)",
					"event": [{
						"listen": "test",
						"script": {
							"exec": [
								"pm.test('Status 403', function () { pm.response.to.have.status(403); });",
								"const r = pm.response.json();",
								"const detailStr = Array.isArray(r.detail) ? (r.detail.map(function(d) { return typeof d === 'object' ? (d.msg || JSON.stringify(d)) : d; }).join(' ')) : (r.detail || '');",
								"pm.test('Detail indicates Supplier restriction (institution or role_type)', function () { pm.expect(detailStr).to.match(/Suppliers?.*(institution|Customer|Employee)|(institution|Customer|Employee).*Suppliers?/); });"
							],
							"type": "text/javascript"
						}
					}],
					"request": {
						"method": "POST",
						"header": [
							{"key": "Authorization", "value": "Bearer {{supplierToken}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"institution_id\": \"22222222-2222-2222-2222-222222222222\",\n  \"role_type\": \"Customer\",\n  \"role_name\": \"Comensal\",\n  \"username\": \"newcustomer\",\n  \"email\": \"newcustomer@example.com\",\n  \"password\": \"TempPass123!\",\n  \"cellphone\": \"8888888888\",\n  \"first_name\": \"New\",\n  \"last_name\": \"Customer\",\n  \"market_id\": \"66666666-6666-6666-6666-666666666666\"\n}"
						},
						"url": "{{baseUrl}}/api/v1/users/"
					}
				}
			]
