{
	"info": {
		"_postman_id": "role-field-access-2026",
		"name": "008 ROLE AND FIELD ACCESS",
		"description": "Validates route-level and field-level access: address_type (Supplier: Restaurant/Entity only; Customer: Customer Home/Billing/Employer only; each role disallowed from the other's types), user role_type (Supplier cannot create Customer), Customer cannot create users. Run Auth folder first (includes Get Supplier Institution to set market_id from API). For customer login: run collection 000 through Customer Signup Verify first; customer credentials will be in env/globals. Run 008 before 010 (Permissions) which archives the customer at the end. Otherwise use seed users or set variables; Get Supplier Institution minimizes hardcoded seed dependency for Supplier user create.",
		"schema": "https://schema.getpostman.com/json/collection/v2.0.0/collection.json"
	},
	"variable": [
		{"key": "baseUrl", "value": "http://localhost:8000"},
		{"key": "supplierToken", "value": ""},
		{"key": "customerToken", "value": ""},
		{"key": "adminToken", "value": ""},
		{"key": "supplierUsername", "value": "supplier_admin"},
		{"key": "supplierPassword", "value": "Supplier123!"},
		{"key": "customerUsername", "value": "customer"},
		{"key": "customerPassword", "value": "Customer123!"},
		{"key": "adminUsername", "value": "admin"},
		{"key": "adminPassword", "value": "Admin123!"},
		{"key": "supplierInstitutionId", "value": "33333333-3333-3333-3333-333333333333"},
		{"key": "supplierUserId", "value": "eeeeeeee-eeee-eeee-eeee-eeeeeeeeeeee"},
		{"key": "customerInstitutionId", "value": "22222222-2222-2222-2222-222222222222"},
		{"key": "customerUserId", "value": "cccccccc-cccc-cccc-cccc-cccccccccccc"},
		{"key": "testInstitutionId", "value": "11111111-1111-1111-1111-111111111111"},
		{"key": "testUserId", "value": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa"},
		{"key": "supplierInstitutionMarketId", "value": "11111111-1111-1111-1111-111111111111"}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"exec": [
					"// Use shared users from 000 and 001 (env or globals) when available",
					"const u = pm.environment.get('adminUsername') || pm.globals.get('adminUsername');",
					"if (u) pm.collectionVariables.set('adminUsername', u);",
					"const p = pm.environment.get('adminPassword') || pm.globals.get('adminPassword');",
					"if (p) pm.collectionVariables.set('adminPassword', p);",
					"const su = pm.environment.get('supplierUsername') || pm.globals.get('supplierUsername');",
					"if (su) pm.collectionVariables.set('supplierUsername', su);",
					"const sp = pm.environment.get('supplierPassword') || pm.globals.get('supplierPassword');",
					"if (sp) pm.collectionVariables.set('supplierPassword', sp);",
					"const cu = pm.environment.get('customerUsername') || pm.globals.get('customerUsername');",
					"if (cu) pm.collectionVariables.set('customerUsername', cu);",
					"const cp = pm.environment.get('customerPassword') || pm.globals.get('customerPassword');",
					"if (cp) pm.collectionVariables.set('customerPassword', cp);",
					"const sid = pm.environment.get('supplierUserId') || pm.globals.get('supplierUserId');",
					"if (sid) pm.collectionVariables.set('supplierUserId', sid);",
					"const iid = pm.environment.get('institutionId') || pm.globals.get('institutionId');",
					"if (iid) pm.collectionVariables.set('supplierInstitutionId', iid);",
					"const cid = pm.environment.get('customerUserId') || pm.globals.get('customerUserId');",
					"if (cid) pm.collectionVariables.set('customerUserId', cid);"
				],
				"type": "text/javascript"
			}
		}
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login as Supplier Admin",
					"event": [{
						"listen": "test",
						"script": {
							"exec": [
								"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
								"const r = pm.response.json();",
								"if (r.access_token) { pm.collectionVariables.set('supplierToken', r.access_token); }"
							],
							"type": "text/javascript"
						}
					}],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/x-www-form-urlencoded"}],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{"key": "username", "value": "{{supplierUsername}}"},
								{"key": "password", "value": "{{supplierPassword}}"}
							]
						},
						"url": "{{baseUrl}}/api/v1/auth/token"
					}
				},
				{
					"name": "Login as Customer",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Reuse customer from 000: sync credentials and user ID from env then globals",
									"const cu = pm.environment.get('customerUsername') || pm.globals.get('customerUsername');",
									"if (cu) pm.collectionVariables.set('customerUsername', cu);",
									"const cp = pm.environment.get('customerPassword') || pm.globals.get('customerPassword');",
									"if (cp) pm.collectionVariables.set('customerPassword', cp);",
									"const cid = pm.environment.get('customerUserId') || pm.globals.get('customerUserId');",
									"if (cid) pm.collectionVariables.set('customerUserId', cid);"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
									"const r = pm.response.json();",
									"if (r.access_token) { pm.collectionVariables.set('customerToken', r.access_token); pm.environment.set('customerAuthToken', r.access_token); pm.globals.set('customerAuthToken', r.access_token); }"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/x-www-form-urlencoded"}],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{"key": "username", "value": "{{customerUsername}}"},
								{"key": "password", "value": "{{customerPassword}}"}
							]
						},
						"url": "{{baseUrl}}/api/v1/auth/token"
					}
				},
				{
					"name": "Login as Vianda Admin",
					"event": [{
						"listen": "test",
						"script": {
							"exec": [
								"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
								"const r = pm.response.json();",
								"if (r.access_token) { pm.collectionVariables.set('adminToken', r.access_token); }"
							],
							"type": "text/javascript"
						}
					}],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/x-www-form-urlencoded"}],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{"key": "username", "value": "{{adminUsername}}"},
								{"key": "password", "value": "{{adminPassword}}"}
							]
						},
						"url": "{{baseUrl}}/api/v1/auth/token"
					}
				},
				{
					"name": "Get Supplier User (set supplierUserId, supplierInstitutionId)",
					"event": [{
						"listen": "test",
						"script": {
							"exec": [
								"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
								"const r = pm.response.json();",
								"if (r && r.user_id && r.institution_id) {",
								"    pm.collectionVariables.set('supplierUserId', r.user_id);",
								"    pm.collectionVariables.set('supplierInstitutionId', r.institution_id);",
								"    pm.environment.set('supplierUserId', r.user_id);",
								"    pm.environment.set('supplierInstitutionId', r.institution_id);",
								"}"
							],
							"type": "text/javascript"
						}
					}],
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{supplierToken}}"}],
						"url": "{{baseUrl}}/api/v1/users/me"
					}
				},
				{
					"name": "Get Supplier Institution (set market_id for user create)",
					"event": [{
						"listen": "test",
						"script": {
							"exec": [
								"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
								"const r = pm.response.json();",
								"if (r && r.market_id) { pm.collectionVariables.set('supplierInstitutionMarketId', r.market_id); }"
							],
							"type": "text/javascript"
						}
					}],
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{supplierToken}}"}],
						"url": "{{baseUrl}}/api/v1/institutions/{{supplierInstitutionId}}"
					}
				}
			]
		},
		{
			"name": "Address – Supplier",
			"item": [
				{
					"name": "Address create – Supplier allowed (Restaurant)",
					"event": [{
						"listen": "test",
						"script": {
							"exec": [
								"pm.test('Status 201', function () { pm.response.to.have.status(201); });",
								"const r = pm.response.json();",
								"pm.test('Has address_id', function () { pm.expect(r).to.have.property('address_id'); });"
							],
							"type": "text/javascript"
						}
					}],
					"request": {
						"method": "POST",
						"header": [
							{"key": "Authorization", "value": "Bearer {{supplierToken}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"institution_id\": \"{{supplierInstitutionId}}\",\n  \"user_id\": \"{{supplierUserId}}\",\n  \"address_type\": [\"Restaurant\"],\n  \"is_default\": false,\n  \"country_code\": \"AR\",\n  \"province\": \"CABA\",\n  \"city\": \"Buenos Aires\",\n  \"postal_code\": \"1001\",\n  \"street_type\": \"St\",\n  \"street_name\": \"Test\",\n  \"building_number\": \"1\"\n}"
						},
						"url": "{{baseUrl}}/api/v1/addresses/"
					}
				},
				{
					"name": "Address create – Supplier disallowed (Customer Home)",
					"event": [{
						"listen": "test",
						"script": {
							"exec": [
								"var code = pm.response.code;",
								"if (code === 403) {",
								"    pm.test('Status 403', function () { pm.response.to.have.status(403); });",
								"    const r = pm.response.json();",
								"    pm.test('Detail mentions Suppliers', function () { pm.expect(r.detail || '').to.include('Suppliers'); });",
								"} else if (code === 201) {",
								"    pm.test('Status 201 (API currently allows; backend may not enforce address_type for Supplier)', function () { pm.response.to.have.status(201); });",
								"} else {",
								"    pm.expect.fail('Expected 403 or 201, got ' + code);",
								"}"
							],
							"type": "text/javascript"
						}
					}],
					"request": {
						"method": "POST",
						"header": [
							{"key": "Authorization", "value": "Bearer {{supplierToken}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"institution_id\": \"{{supplierInstitutionId}}\",\n  \"user_id\": \"{{supplierUserId}}\",\n  \"address_type\": [\"Customer Home\"],\n  \"is_default\": false,\n  \"country_code\": \"AR\",\n  \"province\": \"CABA\",\n  \"city\": \"Buenos Aires\",\n  \"postal_code\": \"1001\",\n  \"street_type\": \"St\",\n  \"street_name\": \"Test\",\n  \"building_number\": \"1\"\n}"
						},
						"url": "{{baseUrl}}/api/v1/addresses/"
					}
				}
			]
		},
