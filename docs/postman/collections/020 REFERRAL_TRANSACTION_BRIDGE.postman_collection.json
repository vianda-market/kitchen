{
  "info": {
    "_postman_id": "d4e5f6a7-b8c9-4d0e-1f2a-3b4c5d6e7f80",
    "name": "020 REFERRAL_TRANSACTION_BRIDGE",
    "description": "Acceptance tests for kitchen #73: customer.referral_transaction bridge table.\n\nVerifies:\n- GET /referrals/my-code returns a referral code for a customer\n- GET /referrals/my-referrals returns referrals with correct shape (no transaction_id field)\n- GET /referrals/stats returns referral summary\n- POST /referrals/assign-code stores a device->code mapping\n- GET /referrals/assigned-code retrieves the stored mapping\n\nNote: The full reward issuance path (process_referral_reward) is triggered internally\nduring subscription payment confirmation and is covered by the 000 E2E collection.\nThis collection verifies the API contract shapes after the bridge migration.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login Super Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "const r = pm.response.json();",
                  "pm.test(\"Has access_token\", () => pm.expect(r).to.have.property('access_token'));",
                  "pm.collectionVariables.set(\"superAdminToken\", r.access_token);",
                  "pm.collectionVariables.set('testMarketId', '00000000-0000-0000-0000-000000000002');",
                  "",
                  "// Fetch AR city_metadata_id for customer signup (IDs regenerate on each DB rebuild).",
                  "const baseUrl = pm.environment.get('baseUrl') || pm.collectionVariables.get('baseUrl') || 'http://localhost:8000';",
                  "pm.sendRequest({",
                  "    url: baseUrl + '/api/v1/cities?country_code=AR&exclude_global=true',",
                  "    method: 'GET',",
                  "    header: { 'Authorization': 'Bearer ' + r.access_token }",
                  "}, function(err, res) {",
                  "    pm.test('AR city fetched for signup', function() {",
                  "        pm.expect(err).to.be.null;",
                  "        pm.expect(res.code).to.equal(200);",
                  "        const cities = res.json();",
                  "        pm.expect(cities).to.be.an('array').with.length.greaterThan(0);",
                  "        pm.collectionVariables.set('cityMetadataId', cities[0].city_metadata_id);",
                  "        console.log('cityMetadataId (AR):', cities[0].city_metadata_id);",
                  "    });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "{{superAdminUsername}}"
                },
                {
                  "key": "password",
                  "value": "{{superAdminPassword}}"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "token"
              ]
            }
          }
        },
        {
          "name": "Signup Request (Customer)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Fixed credentials for idempotency across runs.",
                  "pm.collectionVariables.set('customerEmail', 'referral_tester@example.com');",
                  "pm.collectionVariables.set('customerUsername', 'referral_tester');",
                  "pm.collectionVariables.set('customerPassword', 'Test1234!');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "function detailString(d) {",
                  "    if (typeof d === 'string') { return d.toLowerCase(); }",
                  "    if (d && typeof d === 'object') {",
                  "        return ((d.message || '') + ' ' + (d.code || '')).toLowerCase();",
                  "    }",
                  "    return '';",
                  "}",
                  "const isDuplicate = pm.response.code === 400 && detailString(body.detail).match(/exist|duplicate/);",
                  "if (pm.response.code === 201) {",
                  "    pm.test('Signup request accepted', () => {",
                  "        pm.response.to.have.status(201);",
                  "        pm.expect(body).to.have.property('success', true);",
                  "    });",
                  "} else if (isDuplicate) {",
                  "    // Idempotent: customer exists from prior run \u2014 skip to Login Customer.",
                  "    pm.test('Signup request accepted (existing customer, skipping verification)', () => { pm.expect(true).to.equal(true); });",
                  "    console.log('Customer already exists; skipping to Login Customer');",
                  "    pm.execution.setNextRequest('Login Customer');",
                  "} else {",
                  "    pm.test('Signup request accepted', () => { pm.expect.fail('Unexpected: ' + pm.response.code + ' - ' + JSON.stringify(body)); });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"referral_tester\",\n  \"email\": \"referral_tester@example.com\",\n  \"password\": \"Test1234!\",\n  \"first_name\": \"Referral\",\n  \"last_name\": \"Tester\",\n  \"country_code\": \"AR\",\n  \"city_metadata_id\": \"{{cityMetadataId}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/customers/signup/request",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "customers",
                "signup",
                "request"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Dev Pending Token (Customer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Dev pending token returned', () => {",
                  "    pm.response.to.have.status(200);",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('token');",
                  "    pm.collectionVariables.set('signupVerificationToken', body.token);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/customers/signup/dev-pending-token?email={{customerEmail}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "customers",
                "signup",
                "dev-pending-token"
              ],
              "query": [
                {
                  "key": "email",
                  "value": "{{customerEmail}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Signup Verify (Customer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Signup verified and user created', () => {",
                  "    pm.response.to.have.status(201);",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('user');",
                  "    pm.expect(body).to.have.property('access_token');",
                  "    pm.expect(body.user).to.have.property('user_id');",
                  "    pm.collectionVariables.set('customerUserId', body.user.user_id);",
                  "    // Also pre-set customerToken so Login Customer is optional fallback.",
                  "    pm.collectionVariables.set('customerToken', body.access_token);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{signupVerificationToken}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/customers/signup/verify",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "customers",
                "signup",
                "verify"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Login Customer",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Override urlencoded body with current variable values.",
                  "// (setNextRequest path: template substitution may use stale var snapshot;",
                  "//  pre-request script always runs with the current live variable state.)",
                  "const username = pm.collectionVariables.get('customerUsername') || 'referral_tester';",
                  "pm.request.body.update({",
                  "    mode: 'urlencoded',",
                  "    urlencoded: [",
                  "        { key: 'username', value: username },",
                  "        { key: 'password', value: 'Test1234!' }",
                  "    ]",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "const r = pm.response.json();",
                  "pm.test(\"Has access_token\", () => pm.expect(r).to.have.property('access_token'));",
                  "pm.collectionVariables.set('customerToken', r.access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "{{customerUsername}}"
                },
                {
                  "key": "password",
                  "value": "Test1234!"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "token"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Referral Code",
      "item": [
        {
          "name": "GET my-code \u2014 returns referral_code string",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "const r = pm.response.json();",
                  "pm.test(\"Has referral_code\", () => pm.expect(r).to.have.property('referral_code'));",
                  "pm.test(\"referral_code is a string\", () => pm.expect(r.referral_code).to.be.a('string'));",
                  "pm.collectionVariables.set('referralCode', r.referral_code);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/referrals/my-code",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "referrals",
                "my-code"
              ]
            }
          }
        },
        {
          "name": "GET my-referrals \u2014 list shape has no transaction_id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "const r = pm.response.json();",
                  "pm.test(\"Response is array\", () => pm.expect(r).to.be.an('array'));",
                  "if (r.length > 0) {",
                  "  pm.test(\"No transaction_id on referral row (dropped post-bridge)\", () => {",
                  "    pm.expect(r[0]).to.not.have.property('transaction_id');",
                  "  });",
                  "  pm.test(\"Has referral_id\", () => pm.expect(r[0]).to.have.property('referral_id'));",
                  "  pm.test(\"Has referral_status\", () => pm.expect(r[0]).to.have.property('referral_status'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/referrals/my-referrals",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "referrals",
                "my-referrals"
              ]
            }
          }
        },
        {
          "name": "GET stats \u2014 summary shape",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "const r = pm.response.json();",
                  "pm.test(\"Has total_referrals\", () => pm.expect(r).to.have.property('total_referrals'));",
                  "pm.test(\"Has total_credits_earned\", () => pm.expect(r).to.have.property('total_credits_earned'));",
                  "pm.test(\"Has pending_count\", () => pm.expect(r).to.have.property('pending_count'));",
                  "pm.test(\"total_referrals is number\", () => pm.expect(r.total_referrals).to.be.a('number'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/referrals/stats",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "referrals",
                "stats"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Referral Code Assignment (pre-auth deep link)",
      "item": [
        {
          "name": "POST assign-code \u2014 stores device binding",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('testDeviceId', 'device-' + Date.now());"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "const r = pm.response.json();",
                  "pm.test(\"success is true\", () => pm.expect(r.success).to.equal(true));",
                  "pm.test(\"referral_code echoed back\", () => pm.expect(r.referral_code).to.equal(pm.collectionVariables.get('referralCode')));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"referral_code\": \"{{referralCode}}\",\n  \"device_id\": \"{{testDeviceId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/referrals/assign-code",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "referrals",
                "assign-code"
              ]
            }
          }
        },
        {
          "name": "GET assigned-code \u2014 retrieves binding",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "const r = pm.response.json();",
                  "pm.test(\"referral_code matches assigned code\", () => {",
                  "  pm.expect(r.referral_code).to.equal(pm.collectionVariables.get('referralCode'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/referrals/assigned-code?device_id={{testDeviceId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "referrals",
                "assigned-code"
              ],
              "query": [
                {
                  "key": "device_id",
                  "value": "{{testDeviceId}}"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Contract Shape Assertions",
      "item": [
        {
          "name": "GET my-referrals \u2014 no referral_id on client_transaction (field removed)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// The referral_info response schema never exposed transaction_id",
                  "// and billing.client_transaction no longer carries referral_id.",
                  "// This test documents the post-bridge expected shape.",
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "const r = pm.response.json();",
                  "pm.test(\"Response is array\", () => pm.expect(r).to.be.an('array'));",
                  "r.forEach(function(item) {",
                  "  pm.test(\"Row has referral_id\", () => pm.expect(item).to.have.property('referral_id'));",
                  "  pm.test(\"Row has referral_status\", () => pm.expect(item).to.have.property('referral_status'));",
                  "  pm.test(\"Row does NOT expose transaction_id directly\", () => {",
                  "    pm.expect(item).to.not.have.property('transaction_id');",
                  "  });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/referrals/my-referrals",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "referrals",
                "my-referrals"
              ]
            }
          }
        }
      ]
    }
  ],
