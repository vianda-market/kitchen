{
  "info": {
    "name": "013 SUBSCRIPTION_ACTIONS",
    "description": "Subscription lifecycle: payment details, confirm, hold, resume, cancel, renewal preferences, enriched views. Run collection 000 first (creates customer + subscription). Uses clientUserAuthToken from environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Login Super Admin",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const u = pm.environment.get('superAdminUsername') || pm.globals.get('superAdminUsername') || 'superadmin';",
                  "const p = pm.environment.get('superAdminPassword') || pm.globals.get('superAdminPassword') || 'SuperAdmin1!';",
                  "pm.collectionVariables.set('superAdminUsername', u);",
                  "pm.collectionVariables.set('superAdminPassword', p);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login successful - Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains access_token', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('access_token');",
                  "    pm.expect(body.access_token).to.be.a('string');",
                  "});",
                  "",
                  "const { access_token } = pm.response.json();",
                  "pm.collectionVariables.set('authToken', access_token);",
                  "pm.environment.set('authToken', access_token);",
                  "pm.globals.set('authToken', access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "{{superAdminUsername}}",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "{{superAdminPassword}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "token"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Login Customer",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const u = pm.environment.get('customerUsername') || pm.globals.get('customerUsername');",
                  "const p = pm.environment.get('customerPassword') || pm.globals.get('customerPassword');",
                  "",
                  "if (!u || !p) {",
                  "    throw new Error('customerUsername / customerPassword not set. Run collection 000 first.');",
                  "}",
                  "",
                  "pm.collectionVariables.set('customerUsername', u);",
                  "pm.collectionVariables.set('customerPassword', p);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Customer login successful - Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains access_token', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('access_token');",
                  "});",
                  "",
                  "const { access_token } = pm.response.json();",
                  "pm.collectionVariables.set('customerAuthToken', access_token);",
                  "pm.environment.set('customerAuthToken', access_token);",
                  "pm.globals.set('customerAuthToken', access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "{{customerUsername}}",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "{{customerPassword}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "token"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. Discover Data",
      "item": [
        {
          "name": "Discover Active Subscription",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response is array', function () {",
                  "    const b = pm.response.json();",
                  "    pm.expect(Array.isArray(b)).to.be.true;",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "// subscription_status enum is lowercase; archived subs have is_archived=true, so filter both.",
                  "// Also restrict to subscriptions owned by our customer so we don't pick up someone else's from a prior run.",
                  "const customerUserId = pm.collectionVariables.get('customerUserId') || pm.environment.get('customerUserId');",
                  "const candidates = body.filter(s => !s.is_archived && s.subscription_status !== 'archived');",
                  "const active = customerUserId",
                  "    ? candidates.find(s => String(s.user_id) === String(customerUserId))",
                  "    : candidates[0];",
                  "",
                  "function storeSubscriptionId(id) {",
                  "    pm.collectionVariables.set('subscriptionId', id);",
                  "    pm.environment.set('subscriptionId', id);",
                  "    pm.globals.set('subscriptionId', id);",
                  "    console.log('subscriptionId set:', id);",
                  "}",
                  "",
                  "if (active) {",
                  "    storeSubscriptionId(active.subscription_id);",
                  "} else {",
                  "    // No active subscription for our customer — create one via POST /subscriptions/with-payment.",
                  "    // Collection 000's Cancel Subscription step archives the sub on every full run,",
                  "    // so 013 must bootstrap its own active subscription to run standalone.",
                  "    // IMPORTANT: the create must be done with the customer's token, not the admin's,",
                  "    // because POST /subscriptions/with-payment rejects non-customer role types.",
                  "    const customerToken = pm.collectionVariables.get('customerAuthToken') || pm.environment.get('customerAuthToken');",
                  "    if (!customerToken) { pm.expect.fail('customerAuthToken not set. Run Login Customer first.'); }",
                  "    const baseUrl = pm.environment.get('baseUrl') || pm.collectionVariables.get('baseUrl') || 'http://localhost:8000';",
                  "    console.log('No active subscription for customer; fetching plans to create one.');",
                  "    pm.sendRequest({",
                  "        url: baseUrl + '/api/v1/plans',",
                  "        method: 'GET',",
                  "        header: { 'Authorization': 'Bearer ' + customerToken },",
                  "    }, (err, res) => {",
                  "        if (err || res.code !== 200) { pm.expect.fail('Failed to list plans: ' + (err ? err.message : res.code)); return; }",
                  "        const plans = res.json();",
                  "        // Pick highest-priced plan so Stripe's 50-cent USD minimum (after currency conversion) is satisfied.",
                  "        const firstPlan = Array.isArray(plans) && plans.length > 0",
                  "            ? plans.slice().sort((a, b) => (b.price || 0) - (a.price || 0))[0]",
                  "            : null;",
                  "        if (!firstPlan) { pm.expect.fail('No plans available. Run 000 first.'); return; }",
                  "        const planId = firstPlan.plan_id;",
                  "        pm.sendRequest({",
                  "            url: baseUrl + '/api/v1/subscriptions/with-payment',",
                  "            method: 'POST',",
                  "            header: { 'Authorization': 'Bearer ' + customerToken, 'Content-Type': 'application/json' },",
                  "            body: { mode: 'raw', raw: JSON.stringify({ plan_id: planId }) },",
                  "        }, (err2, res2) => {",
                  "            if (err2 || (res2.code !== 200 && res2.code !== 201)) {",
                  "                pm.expect.fail('Failed to create subscription: ' + (err2 ? err2.message : res2.code + ' ' + res2.text()));",
                  "                return;",
                  "            }",
                  "            const created = res2.json();",
                  "            const subId = created.subscription_id || (created.subscription && created.subscription.subscription_id);",
                  "            if (!subId) { pm.expect.fail('Subscription create did not return subscription_id: ' + JSON.stringify(created)); return; }",
                  "            // Leave subscription in pending state — collection 013 has an explicit",
                  "            // \"Confirm Payment (Mock Only)\" step that will activate it.",
                  "            storeSubscriptionId(subId);",
                  "        });",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customerAuthToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/subscriptions/enriched",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "subscriptions",
                "enriched"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Subscription by ID",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const sid = pm.collectionVariables.get('subscriptionId');",
                  "if (!sid) {",
                  "    console.warn('subscriptionId not set — skipping.');",
                  "    pm.execution.skipRequest();",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Has subscription fields', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('subscription_id');",
                  "    pm.expect(body).to.have.property('subscription_status');",
                  "    pm.expect(body).to.have.property('plan_id');",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "if (body.plan_id) {",
                  "    pm.collectionVariables.set('planId', body.plan_id);",
                  "    pm.environment.set('planId', body.plan_id);",
                  "    pm.globals.set('planId', body.plan_id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customerAuthToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/subscriptions/{{subscriptionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "subscriptions",
                "{{subscriptionId}}"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "3. Payment Details",
      "item": [
        {
          "name": "Get Payment Details",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const status = pm.response.code;",
                  "",
                  "if (status === 200) {",
                  "    pm.test('Payment details returned', function () {",
                  "        const body = pm.response.json();",
                  "        pm.expect(body).to.have.property('payment_id');",
                  "        pm.expect(body).to.have.property('client_secret');",
                  "    });",
                  "} else if (status === 400) {",
                  "    pm.test('400 expected — subscription not Pending', function () {",
                  "        console.log('Subscription already confirmed from 000 run.');",
                  "        pm.expect(status).to.equal(400);",
                  "    });",
                  "} else {",
                  "    pm.test('Unexpected status: ' + status, function () {",
                  "        pm.expect.fail('Expected 200 or 400, got ' + status);",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customerAuthToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/subscriptions/{{subscriptionId}}/payment-details",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "subscriptions",
                "{{subscriptionId}}",
                "payment-details"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Confirm Payment (Mock Only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const status = pm.response.code;",
                  "",
                  "if (status === 200 || status === 201) {",
                  "    pm.test('Payment confirmed', function () {",
                  "        console.log('Confirm payment succeeded (status ' + status + ').');",
                  "        pm.expect(status).to.be.oneOf([200, 201]);",
                  "    });",
                  "} else if (status === 400) {",
                  "    pm.test('400 expected — not Pending or not mock env', function () {",
                  "        const body = pm.response.json();",
                  "        console.log('Confirm payment 400: ' + JSON.stringify(body));",
                  "        pm.expect(status).to.equal(400);",
                  "    });",
                  "} else {",
                  "    pm.test('Unexpected status: ' + status, function () {",
                  "        pm.expect.fail('Expected 200/201/400, got ' + status);",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customerAuthToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/subscriptions/{{subscriptionId}}/confirm-payment",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "subscriptions",
                "{{subscriptionId}}",
                "confirm-payment"
              ]
            }
          },
          "response": []
        }
      ]
