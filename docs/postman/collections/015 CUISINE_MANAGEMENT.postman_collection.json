{
	"info": {
		"_postman_id": "cuisine-management-2026-v1",
		"name": "015 CUISINE_MANAGEMENT",
		"description": "015 – Cuisine Management. Flow: (1) Login Super Admin, (2) Public cuisine list and search, (3) Admin CRUD for cuisines, (4) Supplier suggestion approval flow, (5) Supplier suggestion rejection flow. Requires seeded DB with 22 cuisines. Uses /api/v1/ prefix.",
		"schema": "https://schema.getpostman.com/json/collection/v2.0.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login Super Admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"const response = pm.response.json();",
									"pm.test(\"Response has access_token\", function () {",
									"    pm.expect(response).to.have.property('access_token');",
									"});",
									"",
									"pm.collectionVariables.set(\"superAdminAuthToken\", response.access_token);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "username",
									"value": "{{superAdminUsername}}"
								},
								{
									"key": "password",
									"value": "{{superAdminPassword}}"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/token",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "token"]
						}
					}
				}
			]
		},
		{
			"name": "Public Cuisines API",
			"item": [
				{
					"name": "List All Active Cuisines",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"const response = pm.response.json();",
									"pm.test(\"Response is an array\", function () {",
									"    pm.expect(response).to.be.an('array');",
									"});",
									"",
									"pm.test(\"At least 22 seeded cuisines returned\", function () {",
									"    pm.expect(response.length).to.be.at.least(22);",
									"});",
									"",
									"pm.test(\"Each cuisine has required fields\", function () {",
									"    const first = response[0];",
									"    pm.expect(first).to.have.property('cuisine_id');",
									"    pm.expect(first).to.have.property('cuisine_name');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{superAdminAuthToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/cuisines",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "cuisines"]
						}
					}
				},
				{
					"name": "Search Cuisines by Name",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"const response = pm.response.json();",
									"pm.test(\"Response is an array\", function () {",
									"    pm.expect(response).to.be.an('array');",
									"});",
									"",
									"pm.test(\"Search results contain 'ita' match\", function () {",
									"    pm.expect(response.length).to.be.at.least(1);",
									"    const names = response.map(c => c.cuisine_name.toLowerCase());",
									"    const hasMatch = names.some(n => n.includes('ita'));",
									"    pm.expect(hasMatch).to.be.true;",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{superAdminAuthToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/cuisines?search=ita",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "cuisines"],
							"query": [
								{
									"key": "search",
									"value": "ita"
								}
							]
						}
					}
				}
			]
		},
