        {
          "name": "Get My Favorite IDs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Has plate_ids and restaurant_ids arrays', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('plate_ids');",
                  "    pm.expect(body).to.have.property('restaurant_ids');",
                  "    pm.expect(Array.isArray(body.plate_ids)).to.be.true;",
                  "    pm.expect(Array.isArray(body.restaurant_ids)).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerAuthToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/favorites/me/ids",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "favorites", "me", "ids"]
            }
          },
          "response": []
        },
        {
          "name": "Remove Restaurant Favorite",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 204', function () {",
                  "    pm.response.to.have.status(204);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
