{
	"info": {
		"_postman_id": "timezone-deduction-tests-2026",
		"name": "Timezone Deduction Tests",
		"description": "Test collection for timezone auto-deduction based on country_code and province/state. Tests single-timezone countries (ARG, PER, CHL) and multi-timezone countries (USA, BRA, CAN).",
		"schema": "https://schema.getpostman.com/json/collection/v2.0.0/collection.json"
	},
	"item": [
		{
			"name": "🔐 Authentication",
			"item": [
				{
					"name": "Login as Employee",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"const response = pm.response.json();",
									"pm.test('Response has access_token', function () {",
									"    pm.expect(response).to.have.property('access_token');",
									"});",
									"",
									"pm.collectionVariables.set('authToken', response.access_token);",
									"pm.environment.set('authToken', response.access_token);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "username",
									"value": "{{adminUsername}}"
								},
								{
									"key": "password",
									"value": "{{adminPassword}}"
								}
							]
						},
						"url": "{{baseUrl}}/auth/login"
					}
				}
			]
		},
		{
			"name": "📍 Single-Timezone Countries",
			"item": [
				{
					"name": "Create Address - Argentina (ARG)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 201', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"const response = pm.response.json();",
									"",
									"pm.test('Response has timezone', function () {",
									"    pm.expect(response).to.have.property('timezone');",
									"});",
									"",
									"pm.test('Timezone is America/Argentina/Buenos_Aires', function () {",
									"    pm.expect(response.timezone).to.equal('America/Argentina/Buenos_Aires');",
									"});",
									"",
									"pm.test('country_code is ARG', function () {",
									"    pm.expect(response.country_code).to.equal('ARG');",
									"});",
									"",
									"pm.test('country_name is Argentina', function () {",
									"    pm.expect(response.country_name).to.equal('Argentina');",
									"});",
									"",
									"pm.collectionVariables.set('testAddressArgId', response.address_id);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"institution_id\": \"{{testInstitutionId}}\",\n  \"user_id\": \"{{testUserId}}\",\n  \"address_type\": [\"Restaurant\"],\n  \"country_code\": \"ARG\",\n  \"province\": \"Buenos Aires\",\n  \"city\": \"Buenos Aires\",\n  \"postal_code\": \"C1000\",\n  \"street_type\": \"Avenida\",\n  \"street_name\": \"Corrientes\",\n  \"building_number\": \"1234\"\n}"
