		{
			"name": "✏️ Update Tests",
			"item": [
				{
					"name": "Update Province - Timezone Should Update",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Ensure we have a test address from USA California",
									"const addressId = pm.collectionVariables.get('testAddressUsaCaId');",
									"if (!addressId) {",
									"    throw new Error('Test address from USA California not found. Run USA California test first.');",
									"}"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"const response = pm.response.json();",
									"",
									"pm.test('Province updated to Texas', function () {",
									"    pm.expect(response.province).to.equal('Texas');",
									"});",
									"",
									"pm.test('Timezone updated to America/Chicago', function () {",
									"    pm.expect(response.timezone).to.equal('America/Chicago');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"province\": \"Texas\"\n}"
						},
						"url": "{{baseUrl}}/api/v1/addresses/{{testAddressUsaCaId}}"
					}
				},
